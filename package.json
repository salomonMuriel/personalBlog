{
  "name": "astro-paper",
  "version": "4.2.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro build && jampack ./dist",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check . --plugin=prettier-plugin-astro",
    "format": "prettier --write . --plugin=prettier-plugin-astro",
    "cz": "cz",
    "prepare": "husky install",
    "lint": "eslint .",
    "generate-pdf": "node scripts/generate-pdf.js"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.15",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@marp-team/marp-core": "^4.0.0",
    "@resvg/resvg-js": "^2.6.0",
    "astro": "^6.1.3",
    "astro-embed": "^0.12.0",
    "astro-remote": "^0.3.4",
    "astro-seo-schema": "^6.0.0",
    "fuse.js": "^7.0.0",
    "github-slugger": "^2.0.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.10.11",
    "schema-dts": "^1.1.2",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.2",
    "@divriots/jampack": "^0.23.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/github-slugger": "^1.3.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/parser": "^6.19.0",
    "astro-eslint-parser": "^0.16.2",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.56.0",
    "eslint-plugin-astro": "^0.31.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.2.4",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "puppeteer": "^23.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json,astro}": [
      "prettier --write --plugin=prettier-plugin-astro"
    ]
  },
  "engines": {
    "node": "22.20"
  }
}
