{
  "name": "astro-paper",
  "version": "4.2.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro build && jampack ./dist --exclude 'posts/**'",
    "build:quiet": "bash scripts/build-quiet.sh",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check . --plugin=prettier-plugin-astro",
    "format": "prettier --write . --plugin=prettier-plugin-astro",
    "prepare": "husky install",
    "lint": "eslint .",
    "generate-pdf": "node scripts/generate-pdf.js",
    "sync-linkedin": "node scripts/sync-linkedin.mjs",
    "sync-linkedin:backfill": "node scripts/sync-linkedin.mjs --backfill",
    "og:generate": "node scripts/generate-og-images.mjs",
    "og:generate:force": "node scripts/generate-og-images.mjs --force",
    "og:clear": "rm -rf public/posts/"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/vercel": "^10.0.4",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@fontsource/press-start-2p": "^5.2.7",
    "@fontsource/vt323": "^5.2.7",
    "@marp-team/marp-core": "^4.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "@resvg/resvg-js": "^2.6.0",
    "astro": "^6.1.3",
    "astro-embed": "^0.12.0",
    "astro-remote": "^0.3.4",
    "astro-seo-schema": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.0.0",
    "github-slugger": "^2.0.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.10.11",
    "schema-dts": "^1.1.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.2",
    "@divriots/jampack": "^0.34.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/github-slugger": "^1.3.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/parser": "^8.58.0",
    "astro-eslint-parser": "^1.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.2.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer": "^23.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json,astro}": [
      "prettier --write --plugin=prettier-plugin-astro"
    ]
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
