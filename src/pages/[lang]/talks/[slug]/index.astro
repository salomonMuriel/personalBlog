---
import { type CollectionEntry } from "astro:content";
import Talk from "@layouts/TalkLayout.astro";
import type { Lang } from "@i18n/ui";
import { getLocalizedCollection } from "@i18n/utils";

export interface Props {
  presentation: CollectionEntry<"talks">;
  lang: Lang;
}

export async function getStaticPaths() {
  const langs: Lang[] = ["en", "es"];
  const paths = [];

  for (const lang of langs) {
    const talks = await getLocalizedCollection(lang, "talks");
    paths.push(
      ...talks.map(presentation => ({
        params: { lang, slug: presentation.id },
        props: { presentation, lang },
      }))
    );
  }

  return paths;
}

const { presentation, lang } = Astro.props;
---

<Talk presentation={presentation} lang={lang} />
