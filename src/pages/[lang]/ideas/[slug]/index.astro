---
import { type CollectionEntry, getCollection } from "astro:content";
import Idea from "@layouts/IdeasLayout.astro";
import type { Lang } from "@i18n/ui";

export interface Props {
  idea: CollectionEntry<"ideas">;
  lang: Lang;
}

export async function getStaticPaths() {
  const langs: Lang[] = ["en", "es"];
  const paths = [];

  for (const lang of langs) {
    const collection = lang === "es" ? "ideas-es" : "ideas";
    const ideas = await getCollection(collection);
    paths.push(
      ...ideas.map(idea => ({
        params: { lang, slug: idea.slug },
        props: { idea, lang },
      }))
    );
  }

  return paths;
}

const { idea, lang } = Astro.props;
---

<Idea idea={idea} lang={lang} />
