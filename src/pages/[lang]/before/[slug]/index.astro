---
import { type CollectionEntry } from "astro:content";
import Before from "@layouts/BeforeLayout.astro";
import type { Lang } from "@i18n/ui";
import { getLocalizedCollection } from "@i18n/utils";

export interface Props {
  now: CollectionEntry<"now">;
  lang: Lang;
}

export async function getStaticPaths() {
  const langs: Lang[] = ["en", "es"];
  const paths = [];

  for (const lang of langs) {
    const nows = await getLocalizedCollection(lang, "now");
    paths.push(
      ...nows.map(now => ({
        params: { lang, slug: now.id },
        props: { now, lang },
      }))
    );
  }

  return paths;
}

const { now, lang } = Astro.props;
---

<Before now={now} lang={lang} />
