---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import type { Lang } from "@i18n/ui";
import { getLocalizedCollection } from "@i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = Astro.params.lang as Lang;
const befores = await getLocalizedCollection(lang, "now");
---

<Layout title={`${SITE.title}`} lang={lang}>
  <Header activeNav="now" lang={lang} />
  <Breadcrumbs lang={lang} />
  <main id="main-content">
    <section id="now" class="prose mb-28 max-w-4xl prose-img:border-0">
      <ul>
        {
          befores
            .reverse()
            .splice(1)
            .map(a => (
              <li>
                <a href={`/${lang}/before/${a.id}`}>{a.data.header}</a>
              </li>
            ))
        }
      </ul>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
