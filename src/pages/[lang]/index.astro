---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SOCIALS } from "@config";
import { Image } from "astro:assets";
import salomonImage from "../../assets/images/fotoSalo.jpeg";
import franco from "../../assets/images/franco_cut.webp";
import luca from "../../assets/images/luca_cut.webp";
import { t, getLangTag } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const lang = Astro.params.lang as Lang;

const blogCollection = lang === "es" ? "blog-es" : "blog";
const nowCollection = lang === "es" ? "now-es" : "now";
const talksCollection = lang === "es" ? "talks-es" : "talks";

const posts = await getCollection(blogCollection);
const nows = await getCollection(nowCollection);
const talks = await getCollection(talksCollection);
const sortedPosts = getSortedPosts(posts);
const sortedNows = nows.sort(
  (a, b) => Number(b.data.date) - Number(a.data.date)
);
const sortedTalks = talks.sort(
  (a, b) => Number(b.data.pubDatetime) - Number(a.data.pubDatetime)
);
const latestTalk = sortedTalks[0];
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout lang={lang}>
  <Header lang={lang} />
  <main id="main-content">
    <section id="hero">
      <div class="hero-container">
        <div class="hero-photo-section">
          <div class="hero-photo-wrapper">
            <Image
              src={salomonImage}
              alt={`Salomón Muriel - ${t(lang, "hero.subtitle")}`}
              class="hero-photo"
            />
          </div>
        </div>

        <div class="hero-content-section">
          <h1 class="hero-title">Salomón Muriel</h1>
          <p class="hero-subtitle">{t(lang, "hero.subtitle")}</p>

          <p class="value-prop-subtitle">
            {t(lang, "hero.valueProp")}
          </p>

          <div class="cta-wrapper">
            <button
              data-cal-namespace="30min"
              data-cal-link="salomuriel/30min"
              data-cal-config='{"layout":"month_view"}'
              class="cta-primary"
            >
              {t(lang, "hero.cta")}
            </button>
          </div>

          {
            socialCount > 0 && (
              <div class="social-wrapper">
                <div class="social-links-text">
                  {t(lang, "hero.connectWith")}
                </div>
                <Socials lang={lang} />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <Hr />

    <section id="about-personal">
      <h2>{t(lang, "about.title")}</h2>
      <div class="personal-content">
        <p class="pb-2">
          {t(lang, "about.p1")}
        </p>
        <p class="pb-2">
          {t(lang, "about.p2Start")}{" "}
          <span class="group inline-block"
            >👶👶
            <Image
              src={franco}
              alt="Franco"
              class="group fixed -right-full bottom-0 max-h-[50%] w-auto group-hover:animate-slide-in-out-r"
            />
            <Image
              src={luca}
              alt="Luca"
              class="group fixed -left-full bottom-0 max-h-[50%] w-auto group-hover:animate-slide-in-out-l"
            />
          </span>{t(lang, "about.p2End")}{" "}
          <a
            href="https://www.linkedin.com/in/smuriel/"
            class="underline hover:text-skin-accent"
            target="_blank"
            rel="noopener noreferrer">{t(lang, "about.linkedinLink")}</a
          >.
        </p>
      </div>
    </section>

    <Hr />

    <section id="consultancy">
      <h2>{t(lang, "consultancy.title")}</h2>
      <p class="consultancy-intro">
        {t(lang, "consultancy.intro")}
      </p>

      <div class="services-list">
        <div class="service-item">
          <span class="service-emoji">🤖</span>
          <div class="service-text">
            <strong>{t(lang, "consultancy.aiTitle")}</strong> — {
              t(lang, "consultancy.aiDesc")
            }
          </div>
        </div>
        <div class="service-item">
          <span class="service-emoji">📊</span>
          <div class="service-text">
            <strong>{t(lang, "consultancy.dataTitle")}</strong> — {
              t(lang, "consultancy.dataDesc")
            }
          </div>
        </div>
        <div class="service-item">
          <span class="service-emoji">📈</span>
          <div class="service-text">
            <strong>{t(lang, "consultancy.companyTitle")}</strong> — {
              t(lang, "consultancy.companyDesc")
            }
          </div>
        </div>
        <div class="service-item">
          <span class="service-emoji">🤝</span>
          <div class="service-text">
            <strong>{t(lang, "consultancy.mentorTitle")}</strong> — {
              t(lang, "consultancy.mentorDesc")
            }
          </div>
        </div>
      </div>

      <div class="trust-metrics">
        <span>{t(lang, "consultancy.trust1")}</span>
        <span class="trust-separator">•</span>
        <span>{t(lang, "consultancy.trust2")}</span>
      </div>

      <div class="consultancy-cta-wrapper">
        <button
          data-cal-namespace="personal-site-intro-call"
          data-cal-link="salomuriel/personal-site-intro-call"
          data-cal-config='{"layout":"month_view"}'
          class="cta-primary"
        >
          {t(lang, "consultancy.cta")}
        </button>
        <p class="cta-subtext">
          {t(lang, "consultancy.ctaSub")}
        </p>
      </div>
    </section>

    <Hr />

    <section id="speaking">
      <h2>{t(lang, "speaking.title")}</h2>
      <p class="speaking-intro">
        {t(lang, "speaking.intro")}
      </p>

      <div class="speaking-topics">
        <h3 class="topics-title">{t(lang, "speaking.topicsTitle")}</h3>
        <ul class="topics-list">
          <li>
            🤖 <strong>{t(lang, "speaking.topic1Title")}</strong> - {
              t(lang, "speaking.topic1Desc")
            }
          </li>
          <li>
            📊 <strong>{t(lang, "speaking.topic2Title")}</strong> - {
              t(lang, "speaking.topic2Desc")
            }
          </li>
          <li>
            🚀 <strong>{t(lang, "speaking.topic3Title")}</strong> - {
              t(lang, "speaking.topic3Desc")
            }
          </li>
          <li>
            🏗️ <strong>{t(lang, "speaking.topic4Title")}</strong> - {
              t(lang, "speaking.topic4Desc")
            }
          </li>
        </ul>
      </div>

      {
        latestTalk && (
          <div class="recent-talk-highlight">
            <h3 class="recent-talk-title">{t(lang, "speaking.recentTalk")}</h3>
            <div class="talk-card-featured">
              <h4 class="talk-card-title">{latestTalk.data.title}</h4>
              <p class="talk-card-desc">{latestTalk.data.description}</p>
              <LinkButton
                href={`/${lang}/talks/${latestTalk.slug}/`}
                className="btn-talk-view"
              >
                {t(lang, "speaking.viewPresentation")}
              </LinkButton>
            </div>
          </div>
        )
      }

      <div class="speaking-cta-wrapper">
        <p class="speaking-cta-text">
          {t(lang, "speaking.ctaText")}
        </p>
        <button
          data-cal-namespace="talks-booking"
          data-cal-link="salomuriel/talks"
          data-cal-config='{"layout":"month_view"}'
          class="btn-speaking-primary"
        >
          {t(lang, "speaking.ctaButton")}
        </button>
        <div class="mt-2">
          <LinkButton
            href={`/${lang}/talks/`}
            className="btn-speaking-secondary"
          >
            {t(lang, "speaking.seeAll")}
          </LinkButton>
        </div>
      </div>
    </section>

    <Hr />

    {
      nows.length > 0 && (
        <>
          <section id="now">
            <h2>{t(lang, "now.title")}</h2>
            {t(lang, "now.subtitle")}
            <h3 class="text-lg font-medium text-skin-accent">
              {t(lang, "now.latestUpdate")}
            </h3>
            <ul class="prose">
              <li>
                <a
                  href={`/${lang}/now`}
                  class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                >
                  {sortedNows[0].data.header}
                </a>
              </li>
            </ul>
            <h3 class="text-lg font-medium text-skin-accent">
              {t(lang, "now.previous")}
            </h3>
            <ul class="prose">
              {sortedNows.map(
                ({ data, slug }, index) =>
                  index < 4 &&
                  index > 0 && (
                    <li>
                      <a
                        href={`/${lang}/before/${slug}`}
                        class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                      >
                        {data.header}
                      </a>
                    </li>
                  )
              )}
            </ul>
            <div class="all-posts-btn-wrapper">
              <LinkButton href={`/${lang}/before/`}>
                {t(lang, "now.allPrevious")}
                <svg xmlns="http://www.w3.org/2000/svg">
                  <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
                </svg>
              </LinkButton>
            </div>
          </section>
          <Hr />
        </>
      )
    }
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  #hero {
    @apply pb-8 pt-8;
  }
  .hero-container {
    @apply flex flex-col gap-8;
  }
  @media (min-width: 768px) {
    .hero-container {
      @apply flex-row gap-12 items-center;
    }
  }
  .hero-photo-section {
    @apply flex justify-center w-full flex-shrink-0;
  }
  @media (min-width: 768px) {
    .hero-photo-section {
      @apply justify-start;
      width: 40%;
    }
  }
  .hero-photo-wrapper {
    @apply relative w-full;
    max-width: 300px;
  }
  @media (min-width: 768px) {
    .hero-photo-wrapper {
      max-width: none;
    }
  }
  .hero-photo-wrapper::before {
    content: "";
    @apply absolute rounded-full;
    width: 120%;
    height: 120%;
    top: -10%;
    left: -10%;
    z-index: -1;
    background: radial-gradient(
      circle,
      rgba(255, 111, 89, 0.1) 0%,
      transparent 70%
    );
  }
  .hero-photo {
    @apply w-full h-auto rounded-2xl shadow-xl;
    aspect-ratio: 1/1;
    object-fit: cover;
    border: 1px solid rgba(255, 111, 89, 0.2);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  @media (min-width: 768px) {
    .hero-photo {
      aspect-ratio: 3/4;
    }
  }
  .hero-photo:hover {
    transform: scale(1.02);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-photo {
      transition: none;
    }
    .hero-photo:hover {
      transform: none;
    }
  }
  .hero-content-section {
    @apply flex-1 flex flex-col;
  }
  .hero-title {
    @apply text-4xl font-bold mb-1;
  }
  @media (min-width: 768px) {
    .hero-title {
      @apply text-5xl;
    }
  }
  @media (min-width: 1024px) {
    .hero-title {
      @apply text-6xl;
    }
  }
  .hero-subtitle {
    @apply text-lg text-skin-accent font-medium;
  }
  @media (min-width: 768px) {
    .hero-subtitle {
      @apply text-xl;
    }
  }
  @media (min-width: 1024px) {
    .hero-subtitle {
      @apply text-2xl;
    }
  }
  .value-prop-subtitle {
    @apply text-base mb-6 leading-relaxed;
  }
  @media (min-width: 768px) {
    .value-prop-subtitle {
      @apply text-lg;
    }
  }
  .cta-wrapper {
    @apply mt-6 mb-6 flex flex-col sm:flex-row gap-4;
  }
  .cta-primary {
    @apply rounded-lg bg-skin-accent px-6 py-3 text-lg font-semibold text-skin-inverted hover:bg-opacity-90 transition-all shadow-md hover:shadow-lg cursor-pointer border-0;
  }
  .social-wrapper {
    @apply mt-6 flex flex-col sm:flex-row sm:items-center gap-2;
  }
  .social-links-text {
    @apply text-sm font-medium text-skin-base;
  }
  #consultancy {
    @apply pb-6 pt-6;
  }
  #consultancy h2 {
    @apply text-2xl sm:text-3xl font-bold tracking-wide mb-3;
  }
  .consultancy-intro {
    @apply text-base sm:text-lg mb-6 leading-relaxed;
  }
  .services-list {
    @apply flex flex-col gap-4 my-6;
  }
  .service-item {
    @apply flex gap-3 items-start;
  }
  .service-emoji {
    @apply text-2xl flex-shrink-0 leading-relaxed;
  }
  .service-text {
    @apply text-base sm:text-lg leading-relaxed;
  }
  .service-text strong {
    @apply text-skin-accent;
  }
  .trust-metrics {
    @apply flex flex-wrap justify-center gap-2 sm:gap-4 text-sm sm:text-base text-skin-base/70 my-6 py-4 border-y border-skin-line;
  }
  .trust-separator {
    @apply text-skin-accent;
  }
  .consultancy-cta-wrapper {
    @apply text-center mt-6;
  }
  .cta-subtext {
    @apply text-sm text-skin-base/70 mt-3;
  }
  #speaking {
    @apply pb-6 pt-6;
  }
  #speaking h2 {
    @apply text-2xl sm:text-3xl font-bold tracking-wide mb-3;
  }
  .speaking-intro {
    @apply text-base sm:text-lg mb-6 leading-relaxed;
  }
  .speaking-topics {
    @apply mb-6;
  }
  .topics-title {
    @apply text-lg font-semibold mb-3 text-skin-accent;
  }
  .topics-list {
    @apply list-none space-y-2 ml-0;
  }
  .topics-list li {
    @apply text-sm sm:text-base leading-relaxed;
  }
  .recent-talk-highlight {
    @apply my-6;
  }
  .recent-talk-title {
    @apply text-lg font-semibold mb-3 text-skin-accent;
  }
  .talk-card-featured {
    @apply border-2 border-skin-accent rounded-lg p-5 bg-skin-card-muted;
  }
  .talk-card-title {
    @apply text-xl font-bold mb-2;
  }
  .talk-card-desc {
    @apply text-sm mb-4 leading-relaxed;
  }
  .btn-talk-view {
    @apply inline-block rounded-lg border-2 border-skin-accent px-4 py-2 text-sm font-semibold text-skin-accent no-underline hover:bg-skin-accent hover:text-skin-inverted transition-all;
  }
  .speaking-cta-wrapper {
    @apply mt-6 text-center p-6 bg-skin-card-muted rounded-lg;
  }
  .speaking-cta-text {
    @apply text-base sm:text-lg font-medium mb-4;
  }
  .btn-speaking-primary {
    @apply inline-block rounded-lg bg-skin-accent px-6 py-3 text-lg font-semibold text-skin-inverted hover:bg-opacity-90 transition-all shadow-md cursor-pointer border-0;
  }
  .btn-speaking-secondary {
    @apply inline-block rounded-lg border-2 border-skin-line px-4 py-2 text-sm font-medium text-skin-base no-underline hover:border-skin-accent hover:text-skin-accent transition-all;
  }
  #about-personal {
    @apply pb-6 pt-6;
  }
  #about-personal h2 {
    @apply text-2xl font-semibold tracking-wide mb-4;
  }
  .personal-content {
    @apply text-base leading-relaxed;
  }
  #featured,
  #recent-posts,
  #now {
    @apply pb-6 pt-6;
  }
  #featured h2,
  #recent-posts h2,
  #now h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .all-posts-btn-wrapper {
    @apply my-4 text-center;
  }
</style>
