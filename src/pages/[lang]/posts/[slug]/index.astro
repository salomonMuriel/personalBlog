---
import { type CollectionEntry, getCollection } from "astro:content";
import Posts from "@layouts/Posts.astro";
import PostDetails from "@layouts/PostDetails.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getPageNumbers from "@utils/getPageNumbers";
import getPagination from "@utils/getPagination";
import type { Lang } from "@i18n/ui";

export interface Props {
  post: CollectionEntry<"blog">;
  lang: Lang;
}

export async function getStaticPaths() {
  const langs: Lang[] = ["en", "es"];
  const paths = [];

  for (const lang of langs) {
    const collection = lang === "es" ? "blog-es" : "blog";
    const posts = await getCollection(collection);

    const postResult = posts.map(post => ({
      params: { lang, slug: post.slug },
      props: { post, lang },
    }));

    const pagePaths = getPageNumbers(posts.length).map(pageNum => ({
      params: { lang, slug: String(pageNum) },
      props: { lang },
    }));

    paths.push(...postResult, ...pagePaths);
  }

  return paths;
}

const { slug } = Astro.params;
const { post, lang } = Astro.props;

const blogCollection = lang === "es" ? "blog-es" : "blog";
const posts = await getCollection(blogCollection);
const sortedPosts = getSortedPosts(posts);

const pagination = getPagination({
  posts: sortedPosts,
  page: slug,
});
---

{
  post ? (
    <PostDetails post={post} lang={lang} />
  ) : (
    <Posts {...pagination} lang={lang} />
  )
}
