---
import TagPosts from "@layouts/TagPosts.astro";
import getUniqueTags from "@utils/getUniqueTags";
import getPosts from "@utils/getPosts";
import type { Lang } from "@i18n/ui";
import { getLocalizedCollection } from "@i18n/utils";
import { SITE } from "@config";

export async function getStaticPaths() {
  const langs: Lang[] = ["en", "es"];
  const paths = [];

  for (const lang of langs) {
    const posts = await getLocalizedCollection(lang, "blog");
    const tags = getUniqueTags(posts);

    paths.push(
      ...tags.map(({ tag, tagName }) => ({
        params: { lang, tag },
        props: { tag, tagName, posts, lang },
      }))
    );
  }

  return paths;
}

const { tag, tagName, posts, lang } = Astro.props;
const postsByTag = getPosts(posts, { tag });

const totalPages = Math.ceil(postsByTag.length / SITE.postPerPage);
const paginatedPosts = postsByTag.slice(0, SITE.postPerPage);
---

<TagPosts
  currentPage={1}
  {totalPages}
  {paginatedPosts}
  {tag}
  {tagName}
  lang={lang}
/>
