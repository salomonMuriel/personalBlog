---
import TagPosts from "@layouts/TagPosts.astro";
import getUniqueTags from "@utils/getUniqueTags";
import getPosts from "@utils/getPosts";
import type { Lang } from "@i18n/ui";
import { getLocalizedCollection } from "@i18n/utils";
import { SITE } from "@config";

export async function getStaticPaths() {
  const langs: Lang[] = ["en", "es"];
  const paths = [];

  for (const lang of langs) {
    const posts = await getLocalizedCollection(lang, "blog");
    const tags = getUniqueTags(posts);

    paths.push(
      ...tags.flatMap(({ tag, tagName }) => {
        const tagPosts = getPosts(posts, { tag });
        const totalPages = Math.ceil(tagPosts.length / SITE.postPerPage);

        return Array.from({ length: totalPages }, (_, i) => ({
          params: { lang, tag, page: String(i + 1) },
          props: { tag, tagName, lang },
        }));
      })
    );
  }

  return paths;
}

const { page } = Astro.params;
const { tag, tagName, lang } = Astro.props;

const posts = await getLocalizedCollection(lang, "blog");
const postsByTag = getPosts(posts, { tag });

const currentPage = Number(page);
const totalPages = Math.ceil(postsByTag.length / SITE.postPerPage);
const startIdx = (currentPage - 1) * SITE.postPerPage;
const paginatedPosts = postsByTag.slice(startIdx, startIdx + SITE.postPerPage);
---

<TagPosts
  {currentPage}
  {totalPages}
  {paginatedPosts}
  {tag}
  {tagName}
  lang={lang}
/>
