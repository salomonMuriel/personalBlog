---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SOCIALS } from "@config";
import { Image } from "astro:assets";
import salomonImage from "../assets/images/salomon.jpg";
import franco from "../assets/images/franco_cut.webp";
import luca from "../assets/images/luca_cut.webp";

const posts = await getCollection("blog");
const nows = await getCollection("now");
const talks = await getCollection("talks");
const sortedPosts = getSortedPosts(posts);
const sortedNows = nows.sort((a, b) => b.data.date - a.data.date);
const sortedTalks = talks.sort(
  (a, b) => b.data.pubDatetime - a.data.pubDatetime
);
const latestTalk = sortedTalks[0];
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <div class="flex w-full items-center justify-between pb-6">
        <div class="flex-1">
          <h1 class="hero-title">Salomón Muriel</h1>
          <p class="hero-subtitle">Serial Founder × Data Scientist</p>
        </div>
        <div class="flex flex-1 items-center justify-center">
          <Image
            src={salomonImage}
            alt="Salomón Muriel"
            class="size-24 rounded-full sm:size-32"
          />
        </div>
      </div>

      <h2 class="value-prop">
        Transform Your Business with Tech & AI Innovation
      </h2>
      <p class="value-prop-subtitle">
        I help ambitious companies and founders combine cutting-edge tech & AI
        with proven business strategy—because I've done both: founded 4
        companies AND led data science teams at scale.
      </p>

      <div class="cta-wrapper">
        <button
          data-cal-namespace="30min"
          data-cal-link="salomuriel/30min"
          data-cal-config='{"layout":"month_view"}'
          class="cta-primary"
        >
          Book an Intro Call →
        </button>
        <button
          data-cal-namespace="talks"
          data-cal-link="salomuriel/talks"
          data-cal-config='{"layout":"month_view"}'
          class="cta-secondary"
        >
          Book Me to Speak →
        </button>
      </div>

      {
        // only display if at least one social link is enabled
        socialCount > 0 && (
          <div class="social-wrapper">
            <div class="social-links-text">Connect with me:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    <section id="consultancy">
      <h2>Work With Me</h2>
      <p class="consultancy-intro">
        Tech expertise meets business acumen. Here's how I can help:
      </p>

      <div class="services-grid">
        <div class="service-card">
          <div class="flex items-center gap-4 sm:flex-shrink-0">
            <div class="service-icon">🤖</div>
            <h3 class="service-title sm:hidden">Tech & AI Consulting</h3>
          </div>
          <div class="service-content">
            <h3 class="service-title hidden sm:block">Tech & AI Consulting</h3>
            <p class="service-for">
              <strong>For:</strong> CTOs, Tech Leaders, Product Teams
            </p>
            <p class="service-problem">
              <strong>Problem:</strong> You need technical direction but don't know
              where to start
            </p>
            <p class="service-outcome">
              <strong>Outcome:</strong> Clear roadmap + implementation strategy
            </p>
          </div>
          <div class="service-cta">
            <button
              data-cal-namespace="ai-tech-consulting"
              data-cal-link="salomuriel/ai-tech-consulting"
              data-cal-config='{"layout":"month_view"}'
              class="btn-service"
            >
              Book a Tech Call →
            </button>
          </div>
        </div>

        <div class="service-card">
          <div class="flex items-center gap-4 sm:flex-shrink-0">
            <div class="service-icon">📊</div>
            <h3 class="service-title sm:hidden">Data Science</h3>
          </div>
          <div class="service-content">
            <h3 class="service-title hidden sm:block">Data Science</h3>
            <p class="service-for">
              <strong>For:</strong> Companies with data but no insights
            </p>
            <p class="service-problem">
              <strong>Problem:</strong> Your data isn't driving decisions
            </p>
            <p class="service-outcome">
              <strong>Outcome:</strong> Analytics infrastructure that creates business
              value
            </p>
          </div>
          <div class="service-cta">
            <button
              data-cal-namespace="data-science-consulting"
              data-cal-link="salomuriel/data-science-consulting"
              data-cal-config='{"layout":"month_view"}'
              class="btn-service"
            >
              Book a Data Call →
            </button>
          </div>
        </div>

        <div class="service-card">
          <div class="flex items-center gap-4 sm:flex-shrink-0">
            <div class="service-icon">📈</div>
            <h3 class="service-title sm:hidden">Company-Building</h3>
          </div>
          <div class="service-content">
            <h3 class="service-title hidden sm:block">Company-Building</h3>
            <p class="service-for">
              <strong>For:</strong> Founders, CEOs, Growth-stage companies
            </p>
            <p class="service-problem">
              <strong>Problem:</strong> Scaling is chaotic and mistakes are slowing
              growth
            </p>
            <p class="service-outcome">
              <strong>Outcome:</strong> Proven playbooks from 4 companies built from
              scratch
            </p>
          </div>
          <div class="service-cta">
            <button
              data-cal-namespace="company-building-consulting"
              data-cal-link="salomuriel/company-building-consulting"
              data-cal-config='{"layout":"month_view"}'
              class="btn-service"
            >
              Book a Founder Call →
            </button>
          </div>
        </div>

        <div class="service-card">
          <div class="flex items-center gap-4 sm:flex-shrink-0">
            <div class="service-icon">🤝</div>
            <h3 class="service-title sm:hidden">Mentorship</h3>
          </div>
          <div class="service-content">
            <h3 class="service-title hidden sm:block">Mentorship</h3>
            <p class="service-for">
              <strong>For:</strong> Aspiring founders, data scientists, product leaders
            </p>
            <p class="service-problem">
              <strong>Problem:</strong> You need guidance from someone in the trenches
            </p>
            <p class="service-outcome">
              <strong>Outcome:</strong> Actionable advice and accountability
            </p>
          </div>
          <div class="service-cta">
            <button
              data-cal-namespace="mentorship"
              data-cal-link="salomuriel/mentorship"
              data-cal-config='{"layout":"month_view"}'
              class="btn-service"
            >
              Book a Mentorship Call →
            </button>
          </div>
        </div>
      </div>

      <div class="consultancy-footer">
        <p class="not-sure">
          <strong>Not sure which fits your needs?</strong>
          <a
            data-cal-link="salomuriel/personal-site-intro-call"
            data-cal-namespace="personal-site-intro-call"
            data-cal-config='{"layout":"month_view","theme":"dark"}'
            class="underline cursor-pointer hover:text-skin-accent ml-2"
          >
            Book a free 15-minute intro call
          </a>
        </p>
      </div>
    </section>

    <Hr />

    <section id="speaking">
      <h2>Speaking & Workshops</h2>
      <p class="speaking-intro">
        I speak about AI & tech, data science, and entrepreneurship—combining
        technical depth with practical business insights.
      </p>

      <div class="speaking-topics">
        <h3 class="topics-title">Popular Topics:</h3>
        <ul class="topics-list">
          <li>
            🤖 <strong>AI & Tech</strong> - Practical AI applications and cutting-edge
            technology for business impact
          </li>
          <li>
            📊 <strong>Data-Driven Decision Making</strong> - Building analytics
            culture in growing companies
          </li>
          <li>
            🚀 <strong>The Maker's Mindset</strong> - From idea to launched product:
            lessons from 4 companies
          </li>
          <li>
            🏗️ <strong>Entrepreneurship</strong> - Practical strategies for founders
            and scale-ups
          </li>
        </ul>
      </div>

      {
        latestTalk && (
          <div class="recent-talk-highlight">
            <h3 class="recent-talk-title">Recent Talk:</h3>
            <div class="talk-card-featured">
              <h4 class="talk-card-title">{latestTalk.data.title}</h4>
              <p class="talk-card-desc">{latestTalk.data.description}</p>
              <LinkButton
                href={`/talks/${latestTalk.slug}/`}
                className="btn-talk-view"
              >
                View Presentation →
              </LinkButton>
            </div>
          </div>
        )
      }

      <div class="speaking-cta-wrapper">
        <p class="speaking-cta-text">
          Looking for a speaker who bridges technical and business perspectives?
        </p>
        <button
          data-cal-namespace="talks-booking"
          data-cal-link="salomuriel/talks"
          data-cal-config='{"layout":"month_view"}'
          class="btn-speaking-primary"
        >
          Book Me to Speak →
        </button>
        <div class="mt-2">
          <LinkButton href="/talks/" className="btn-speaking-secondary">
            See All Talks
          </LinkButton>
        </div>
      </div>
    </section>

    <Hr />

    <section id="about-personal">
      <h2>About Me</h2>
      <div class="personal-content">
        <p class="pb-2">
          I'm a serial founder with <strong>4 companies under my belt</strong> and
          building my 5th. I'm also a leading data scientist who loves making impact
          through data and innovation.
        </p>
        <p class="pb-2">
          Beyond business, I'm the father of super-twins, Luca & Franco{" "}
          <span class="group inline-block"
            >👶👶
            <Image
              src={franco}
              alt="Franco"
              class="group fixed -right-full bottom-0 max-h-[50%] w-auto group-hover:animate-slide-in-out-r"
            />
            <Image
              src={luca}
              alt="Luca"
              class="group fixed -left-full bottom-0 max-h-[50%] w-auto group-hover:animate-slide-in-out-l"
            />
          </span>. I often write about Entrepreneurship, Education, Tech & Data
          Science, and Life Balance.
        </p>
        <p>
          I'm always eager to meet creative, interesting, innovative people.
        </p>
      </div>
    </section>

    <Hr />

    {
      nows.length > 0 && (
        <>
          <section id="now">
            <h2>Now</h2>
            Updates on what's happening in my life... right now.
            <h3 class="text-lg font-medium text-skin-accent">Latest Update</h3>
            <ul class="prose">
              <li>
                <a
                  href={"/now"}
                  class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                >
                  {nows[0].data.header}
                </a>
              </li>
            </ul>
            <h3 class="text-lg font-medium text-skin-accent">Previous</h3>
            <ul class="prose">
              {nows.map(
                ({ data, slug }, index) =>
                  index < 4 &&
                  index > 0 && (
                    <li>
                      <a
                        href={`/before/${slug}`}
                        class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                      >
                        {data.header}
                      </a>
                    </li>
                  )
              )}
            </ul>
            <div class="all-posts-btn-wrapper">
              <LinkButton href="/before/">
                All Previous Updates
                <svg xmlns="http://www.w3.org/2000/svg">
                  <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
                </svg>
              </LinkButton>
            </div>
          </section>
          <Hr />
        </>
      )
    }

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured">
            <h2>Featured</h2>
            <ul>
              {featuredPosts.map(({ data, slug }) => (
                <Card
                  href={`/posts/${slug}/`}
                  frontmatter={data}
                  secHeading={false}
                />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <h2>Recent Posts</h2>
          <ul>
            {recentPosts.map(
              ({ data, slug }, index) =>
                index < 4 && (
                  <Card
                    href={`/posts/${slug}/`}
                    frontmatter={data}
                    secHeading={false}
                  />
                )
            )}
          </ul>
        </section>
      )
    }

    {
      sortedPosts.length > 0 && (
        <div class="all-posts-btn-wrapper">
          <LinkButton href="/posts/">
            All Posts
            <svg xmlns="http://www.w3.org/2000/svg">
              <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
            </svg>
          </LinkButton>
        </div>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-8 pt-8;
  }

  .hero-title {
    @apply text-4xl font-bold sm:text-5xl mb-1;
  }

  .hero-subtitle {
    @apply text-lg sm:text-xl text-skin-accent font-medium;
  }

  .value-prop {
    @apply text-2xl sm:text-3xl font-bold mt-6 mb-3 leading-tight;
  }

  .value-prop-subtitle {
    @apply text-base sm:text-lg mb-6 leading-relaxed;
  }

  .cta-wrapper {
    @apply mt-6 mb-6 flex flex-col sm:flex-row gap-3 sm:gap-4;
  }

  .cta-primary {
    @apply rounded-lg bg-skin-accent px-6 py-3 text-lg font-semibold text-skin-inverted hover:bg-opacity-90 transition-all shadow-md hover:shadow-lg cursor-pointer border-0;
  }

  .cta-secondary {
    @apply rounded-lg border-2 border-skin-accent px-6 py-3 text-lg font-semibold text-skin-accent bg-transparent hover:bg-skin-accent hover:text-skin-inverted transition-all cursor-pointer;
  }

  .social-wrapper {
    @apply mt-6 flex flex-col sm:flex-row sm:items-center gap-2;
  }

  .social-links-text {
    @apply text-sm font-medium text-skin-base;
  }

  /* ===== Consultancy Section ===== */
  #consultancy {
    @apply pb-6 pt-6;
  }

  #consultancy h2 {
    @apply text-2xl sm:text-3xl font-bold tracking-wide mb-3;
  }

  .consultancy-intro {
    @apply text-base sm:text-lg mb-6 leading-relaxed;
  }

  .services-grid {
    @apply flex flex-col gap-6 my-6;
  }

  .service-card {
    @apply border-2 border-skin-line rounded-lg p-4 hover:border-skin-accent transition-all hover:shadow-lg flex flex-col sm:flex-row gap-4 sm:gap-6 sm:items-center;
  }

  .service-icon {
    @apply text-5xl sm:text-6xl flex-shrink-0;
  }

  .service-content {
    @apply flex-1;
  }

  .service-title {
    @apply text-xl sm:text-2xl font-bold mb-2 text-skin-accent;
  }

  .service-for,
  .service-problem,
  .service-outcome {
    @apply text-sm sm:text-base mb-2 leading-relaxed;
  }

  .service-cta {
    @apply flex items-center justify-center sm:justify-center flex-shrink-0 w-full sm:w-auto;
  }

  .btn-service {
    @apply inline-block rounded-lg bg-skin-accent px-5 py-3 text-sm sm:text-base font-semibold text-skin-inverted hover:bg-opacity-90 transition-all cursor-pointer border-0 w-full sm:w-auto;
  }

  .consultancy-footer {
    @apply mt-6 text-center p-4 bg-skin-card-muted rounded-lg;
  }

  .not-sure {
    @apply text-base;
  }

  /* ===== Speaking Section ===== */
  #speaking {
    @apply pb-6 pt-6;
  }

  #speaking h2 {
    @apply text-2xl sm:text-3xl font-bold tracking-wide mb-3;
  }

  .speaking-intro {
    @apply text-base sm:text-lg mb-6 leading-relaxed;
  }

  .speaking-topics {
    @apply mb-6;
  }

  .topics-title {
    @apply text-lg font-semibold mb-3 text-skin-accent;
  }

  .topics-list {
    @apply list-none space-y-2 ml-0;
  }

  .topics-list li {
    @apply text-sm sm:text-base leading-relaxed;
  }

  .recent-talk-highlight {
    @apply my-6;
  }

  .recent-talk-title {
    @apply text-lg font-semibold mb-3 text-skin-accent;
  }

  .talk-card-featured {
    @apply border-2 border-skin-accent rounded-lg p-5 bg-skin-card-muted;
  }

  .talk-card-title {
    @apply text-xl font-bold mb-2;
  }

  .talk-card-desc {
    @apply text-sm mb-4 leading-relaxed;
  }

  .btn-talk-view {
    @apply inline-block rounded-lg border-2 border-skin-accent px-4 py-2 text-sm font-semibold text-skin-accent no-underline hover:bg-skin-accent hover:text-skin-inverted transition-all;
  }

  .speaking-cta-wrapper {
    @apply mt-6 text-center p-6 bg-skin-card-muted rounded-lg;
  }

  .speaking-cta-text {
    @apply text-base sm:text-lg font-medium mb-4;
  }

  .btn-speaking-primary {
    @apply inline-block rounded-lg bg-skin-accent px-6 py-3 text-lg font-semibold text-skin-inverted hover:bg-opacity-90 transition-all shadow-md cursor-pointer border-0;
  }

  .btn-speaking-secondary {
    @apply inline-block rounded-lg border-2 border-skin-line px-4 py-2 text-sm font-semibold text-skin-base no-underline hover:border-skin-accent hover:text-skin-accent transition-all;
  }

  /* ===== About Personal Section ===== */
  #about-personal {
    @apply pb-6 pt-6;
  }

  #about-personal h2 {
    @apply text-2xl font-semibold tracking-wide mb-4;
  }

  .personal-content {
    @apply text-base leading-relaxed;
  }

  /* ===== Featured & Recent Posts Sections ===== */
  #featured,
  #recent-posts,
  #now {
    @apply pb-6 pt-6;
  }

  #featured h2,
  #recent-posts h2,
  #now h2 {
    @apply text-2xl font-semibold tracking-wide;
  }

  .all-posts-btn-wrapper {
    @apply my-4 text-center;
  }
</style>
