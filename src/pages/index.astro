---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SOCIALS } from "@config";
import { Image } from "astro:assets";
import salomonImage from "../assets/images/fotoSalo.jpeg";
import franco from "../assets/images/franco_cut.webp";
import luca from "../assets/images/luca_cut.webp";

const posts = await getCollection("blog");
const nows = await getCollection("now");
const talks = await getCollection("talks");
const sortedPosts = getSortedPosts(posts);
const sortedNows = nows.sort((a, b) => b.data.date - a.data.date);
const sortedTalks = talks.sort(
  (a, b) => b.data.pubDatetime - a.data.pubDatetime
);
const latestTalk = sortedTalks[0];
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <div class="hero-container">
        <!-- Photo Section (Left on Desktop, Top on Mobile) -->
        <div class="hero-photo-section">
          <div class="hero-photo-wrapper">
            <Image
              src={salomonImage}
              alt="Salomón Muriel - Serial Entrepreneur and Tech Leader"
              class="hero-photo"
            />
          </div>
        </div>

        <!-- Content Section (Right on Desktop, Bottom on Mobile) -->
        <div class="hero-content-section">
          <h1 class="hero-title">Salomón Muriel</h1>
          <p class="hero-subtitle">Serial Entrepreneur and Tech Leader</p>

          <p class="value-prop-subtitle">
            I've founded 4 companies and led Tech, AI & Data teams at scale. I
            consult with founders and companies, and speak at conferences and
            corporate events.
          </p>

          <div class="cta-wrapper">
            <button
              data-cal-namespace="30min"
              data-cal-link="salomuriel/30min"
              data-cal-config='{"layout":"month_view"}'
              class="cta-primary"
            >
              Let's Talk →
            </button>
          </div>

          {
            // only display if at least one social link is enabled
            socialCount > 0 && (
              <div class="social-wrapper">
                <div class="social-links-text">Connect with me:</div>
                <Socials />
              </div>
            )
          }
        </div>
      </div>
    </section>

    <Hr />

    <section id="about-personal">
      <h2>About Me</h2>
      <div class="personal-content">
        <p class="pb-2">
          I've founded 4 companies (building #5 now) and led Tech, AI & Data
          teams at scale. I combine technical depth with real-world business
          experience.
        </p>
        <p class="pb-2">
          Beyond business, I'm a dad to twin boys, Luca & Franco{" "}
          <span class="group inline-block"
            >👶👶
            <Image
              src={franco}
              alt="Franco"
              class="group fixed -right-full bottom-0 max-h-[50%] w-auto group-hover:animate-slide-in-out-r"
            />
            <Image
              src={luca}
              alt="Luca"
              class="group fixed -left-full bottom-0 max-h-[50%] w-auto group-hover:animate-slide-in-out-l"
            />
          </span>. I write about Entrepreneurship, Education, Tech, Data
          Science, and Life Balance—most of what I write <a
            href="https://www.linkedin.com/in/smuriel/"
            class="underline hover:text-skin-accent"
            target="_blank"
            rel="noopener noreferrer">is on LinkedIn</a
          >.
        </p>
      </div>
    </section>

    <Hr />

    <section id="consultancy">
      <h2>Work With Me</h2>
      <p class="consultancy-intro">
        I partner with founders, CTOs, and growing companies to solve their
        toughest challenges. Whether you need hands-on technical guidance or
        strategic advice, I bring real experience from building 4 companies and
        leading teams at scale.
      </p>

      <div class="services-list">
        <div class="service-item">
          <span class="service-emoji">🤖</span>
          <div class="service-text">
            <strong>Tech & AI Consulting</strong> — Navigate AI adoption, build technical
            roadmaps, and make implementation decisions with confidence.
          </div>
        </div>
        <div class="service-item">
          <span class="service-emoji">📊</span>
          <div class="service-text">
            <strong>Data Science</strong> — Turn your data into actionable insights
            and build analytics capabilities that drive real business decisions.
          </div>
        </div>
        <div class="service-item">
          <span class="service-emoji">📈</span>
          <div class="service-text">
            <strong>Company-Building</strong> — Learn from hard-won lessons across
            4 companies: fundraising, hiring, scaling, and avoiding the mistakes
            I've already made.
          </div>
        </div>
        <div class="service-item">
          <span class="service-emoji">🤝</span>
          <div class="service-text">
            <strong>Mentorship</strong> — Ongoing accountability and guidance for
            founders, data scientists, and tech leaders navigating their next chapter.
          </div>
        </div>
      </div>

      <div class="trust-metrics">
        <span>4 companies founded</span>
        <span class="trust-separator">•</span>
        <span>10+ years in tech</span>
      </div>

      <div class="consultancy-cta-wrapper">
        <button
          data-cal-namespace="personal-site-intro-call"
          data-cal-link="salomuriel/personal-site-intro-call"
          data-cal-config='{"layout":"month_view"}'
          class="cta-primary"
        >
          Book a Free Intro Call →
        </button>
        <p class="cta-subtext">
          15 minutes to discuss your needs — no pitch, no pressure.
        </p>
      </div>
    </section>

    <Hr />

    <section id="speaking">
      <h2>Speaking & Workshops</h2>
      <p class="speaking-intro">
        I speak about AI, data science, and building companies—technical depth
        meets business reality.
      </p>

      <div class="speaking-topics">
        <h3 class="topics-title">Popular Topics:</h3>
        <ul class="topics-list">
          <li>
            🤖 <strong>AI & Tech</strong> - Practical applications for business impact
          </li>
          <li>
            📊 <strong>Data-Driven Decisions</strong> - Building analytics culture
            in growing companies
          </li>
          <li>
            🚀 <strong>The Maker's Mindset</strong> - From idea to product: lessons
            from 4 companies
          </li>
          <li>
            🏗️ <strong>Entrepreneurship</strong> - Practical strategies for founders
            and scale-ups
          </li>
        </ul>
      </div>

      {
        latestTalk && (
          <div class="recent-talk-highlight">
            <h3 class="recent-talk-title">Recent Talk:</h3>
            <div class="talk-card-featured">
              <h4 class="talk-card-title">{latestTalk.data.title}</h4>
              <p class="talk-card-desc">{latestTalk.data.description}</p>
              <LinkButton
                href={`/talks/${latestTalk.slug}/`}
                className="btn-talk-view"
              >
                View Presentation →
              </LinkButton>
            </div>
          </div>
        )
      }

      <div class="speaking-cta-wrapper">
        <p class="speaking-cta-text">
          Need a speaker who's been in the code AND the boardroom?
        </p>
        <button
          data-cal-namespace="talks-booking"
          data-cal-link="salomuriel/talks"
          data-cal-config='{"layout":"month_view"}'
          class="btn-speaking-primary"
        >
          Book Me to Speak →
        </button>
        <div class="mt-2">
          <LinkButton href="/talks/" className="btn-speaking-secondary">
            See All Talks
          </LinkButton>
        </div>
      </div>
    </section>

    <Hr />

    {
      nows.length > 0 && (
        <>
          <section id="now">
            <h2>Now</h2>
            Updates on what's happening in my life... right now.
            <h3 class="text-lg font-medium text-skin-accent">Latest Update</h3>
            <ul class="prose">
              <li>
                <a
                  href={"/now"}
                  class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                >
                  {nows[0].data.header}
                </a>
              </li>
            </ul>
            <h3 class="text-lg font-medium text-skin-accent">Previous</h3>
            <ul class="prose">
              {nows.map(
                ({ data, slug }, index) =>
                  index < 4 &&
                  index > 0 && (
                    <li>
                      <a
                        href={`/before/${slug}`}
                        class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                      >
                        {data.header}
                      </a>
                    </li>
                  )
              )}
            </ul>
            <div class="all-posts-btn-wrapper">
              <LinkButton href="/before/">
                All Previous Updates
                <svg xmlns="http://www.w3.org/2000/svg">
                  <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
                </svg>
              </LinkButton>
            </div>
          </section>
          <Hr />
        </>
      )
    }

    {
      /* Featured posts section hidden - uncomment to restore
      featuredPosts.length > 0 && (
        <>
          <section id="featured">
            <h2>Featured</h2>
            <ul>
              {featuredPosts.map(({ data, slug }) => (
                <Card
                  href={`/posts/${slug}/`}
                  frontmatter={data}
                  secHeading={false}
                />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    */
    }

    {
      /* Recent posts section hidden - uncomment to restore
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <h2>Recent Posts</h2>
          <ul>
            {recentPosts.map(
              ({ data, slug }, index) =>
                index < 4 && (
                  <Card
                    href={`/posts/${slug}/`}
                    frontmatter={data}
                    secHeading={false}
                  />
                )
            )}
          </ul>
        </section>
      )
    */
    }

    {
      /* All posts button hidden - uncomment to restore
      sortedPosts.length > 0 && (
        <div class="all-posts-btn-wrapper">
          <LinkButton href="/posts/">
            All Posts
            <svg xmlns="http://www.w3.org/2000/svg">
              <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
            </svg>
          </LinkButton>
        </div>
      )
    */
    }
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-8 pt-8;
  }

  .hero-container {
    @apply flex flex-col gap-8;
  }

  /* Desktop: Split-screen layout (photo left 40%, content right 60%) */
  @media (min-width: 768px) {
    .hero-container {
      @apply flex-row gap-12 items-center;
    }
  }

  /* Photo Section */
  .hero-photo-section {
    @apply flex justify-center;
    @apply w-full;
    @apply flex-shrink-0;
  }

  @media (min-width: 768px) {
    .hero-photo-section {
      @apply justify-start;
      width: 40%;
    }
  }

  .hero-photo-wrapper {
    @apply relative;
    @apply w-full;
    max-width: 300px;
  }

  @media (min-width: 768px) {
    .hero-photo-wrapper {
      max-width: none;
    }
  }

  /* Gradient background blob behind photo */
  .hero-photo-wrapper::before {
    content: "";
    @apply absolute rounded-full;
    width: 120%;
    height: 120%;
    top: -10%;
    left: -10%;
    z-index: -1;
    background: radial-gradient(
      circle,
      rgba(255, 111, 89, 0.1) 0%,
      transparent 70%
    );
  }

  .hero-photo {
    @apply w-full h-auto rounded-2xl shadow-xl;
    aspect-ratio: 1/1;
    object-fit: cover;
    border: 1px solid rgba(255, 111, 89, 0.2);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  @media (min-width: 768px) {
    .hero-photo {
      aspect-ratio: 3/4;
    }
  }

  .hero-photo:hover {
    transform: scale(1.02);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
  }

  /* Support for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-photo {
      transition: none;
    }
    .hero-photo:hover {
      transform: none;
    }
  }

  /* Content Section */
  .hero-content-section {
    @apply flex-1 flex flex-col;
  }

  .hero-title {
    @apply text-4xl font-bold mb-1;
  }

  @media (min-width: 768px) {
    .hero-title {
      @apply text-5xl;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      @apply text-6xl;
    }
  }

  .hero-subtitle {
    @apply text-lg text-skin-accent font-medium;
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      @apply text-xl;
    }
  }

  @media (min-width: 1024px) {
    .hero-subtitle {
      @apply text-2xl;
    }
  }

  .value-prop {
    @apply text-2xl font-bold mt-6 mb-3 leading-tight;
  }

  @media (min-width: 768px) {
    .value-prop {
      @apply text-3xl;
    }
  }

  @media (min-width: 1024px) {
    .value-prop {
      @apply text-4xl;
    }
  }

  .value-prop-subtitle {
    @apply text-base mb-6 leading-relaxed;
  }

  @media (min-width: 768px) {
    .value-prop-subtitle {
      @apply text-lg;
    }
  }

  .cta-wrapper {
    @apply mt-6 mb-6 flex flex-col sm:flex-row gap-4;
  }

  .cta-primary {
    @apply rounded-lg bg-skin-accent px-6 py-3 text-lg font-semibold text-skin-inverted hover:bg-opacity-90 transition-all shadow-md hover:shadow-lg cursor-pointer border-0;
  }

  .cta-secondary {
    @apply rounded-lg border-2 border-skin-accent px-6 py-3 text-lg font-semibold text-skin-accent bg-transparent hover:bg-skin-accent hover:text-skin-inverted transition-all cursor-pointer;
  }

  .social-wrapper {
    @apply mt-6 flex flex-col sm:flex-row sm:items-center gap-2;
  }

  .social-links-text {
    @apply text-sm font-medium text-skin-base;
  }

  /* ===== Consultancy Section ===== */
  #consultancy {
    @apply pb-6 pt-6;
  }

  #consultancy h2 {
    @apply text-2xl sm:text-3xl font-bold tracking-wide mb-3;
  }

  .consultancy-intro {
    @apply text-base sm:text-lg mb-6 leading-relaxed;
  }

  .services-list {
    @apply flex flex-col gap-4 my-6;
  }

  .service-item {
    @apply flex gap-3 items-start;
  }

  .service-emoji {
    @apply text-2xl flex-shrink-0 leading-relaxed;
  }

  .service-text {
    @apply text-base sm:text-lg leading-relaxed;
  }

  .service-text strong {
    @apply text-skin-accent;
  }

  .trust-metrics {
    @apply flex flex-wrap justify-center gap-2 sm:gap-4 text-sm sm:text-base text-skin-base/70 my-6 py-4 border-y border-skin-line;
  }

  .trust-separator {
    @apply text-skin-accent;
  }

  .consultancy-cta-wrapper {
    @apply text-center mt-6;
  }

  .cta-subtext {
    @apply text-sm text-skin-base/70 mt-3;
  }

  /* ===== Speaking Section ===== */
  #speaking {
    @apply pb-6 pt-6;
  }

  #speaking h2 {
    @apply text-2xl sm:text-3xl font-bold tracking-wide mb-3;
  }

  .speaking-intro {
    @apply text-base sm:text-lg mb-6 leading-relaxed;
  }

  .speaking-topics {
    @apply mb-6;
  }

  .topics-title {
    @apply text-lg font-semibold mb-3 text-skin-accent;
  }

  .topics-list {
    @apply list-none space-y-2 ml-0;
  }

  .topics-list li {
    @apply text-sm sm:text-base leading-relaxed;
  }

  .recent-talk-highlight {
    @apply my-6;
  }

  .recent-talk-title {
    @apply text-lg font-semibold mb-3 text-skin-accent;
  }

  .talk-card-featured {
    @apply border-2 border-skin-accent rounded-lg p-5 bg-skin-card-muted;
  }

  .talk-card-title {
    @apply text-xl font-bold mb-2;
  }

  .talk-card-desc {
    @apply text-sm mb-4 leading-relaxed;
  }

  .btn-talk-view {
    @apply inline-block rounded-lg border-2 border-skin-accent px-4 py-2 text-sm font-semibold text-skin-accent no-underline hover:bg-skin-accent hover:text-skin-inverted transition-all;
  }

  .speaking-cta-wrapper {
    @apply mt-6 text-center p-6 bg-skin-card-muted rounded-lg;
  }

  .speaking-cta-text {
    @apply text-base sm:text-lg font-medium mb-4;
  }

  .btn-speaking-primary {
    @apply inline-block rounded-lg bg-skin-accent px-6 py-3 text-lg font-semibold text-skin-inverted hover:bg-opacity-90 transition-all shadow-md cursor-pointer border-0;
  }

  .btn-speaking-secondary {
    @apply inline-block rounded-lg border-2 border-skin-line px-4 py-2 text-sm font-medium text-skin-base no-underline hover:border-skin-accent hover:text-skin-accent transition-all;
  }

  /* ===== About Personal Section ===== */
  #about-personal {
    @apply pb-6 pt-6;
  }

  #about-personal h2 {
    @apply text-2xl font-semibold tracking-wide mb-4;
  }

  .personal-content {
    @apply text-base leading-relaxed;
  }

  /* ===== Featured & Recent Posts Sections ===== */
  #featured,
  #recent-posts,
  #now {
    @apply pb-6 pt-6;
  }

  #featured h2,
  #recent-posts h2,
  #now h2 {
    @apply text-2xl font-semibold tracking-wide;
  }

  .all-posts-btn-wrapper {
    @apply my-4 text-center;
  }
</style>
