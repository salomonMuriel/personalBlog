---
import { LOCALE, SITE } from "@config";
import "@fontsource-variable/dm-sans";
import "@fontsource-variable/syne";
import "@styles/base.css";
import { ViewTransitions } from "astro:transitions";
import { Schema } from "astro-seo-schema";
import { t, getLangTag } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";

const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

export interface Props {
  title?: string;
  author?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  lang?: Lang;
}

const {
  title = SITE.title,
  author = SITE.author,
  description = SITE.desc,
  ogImage = SITE.ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  lang = defaultLang,
} = Astro.props;

const socialImageURL = new URL(
  ogImage ?? SITE.ogImage ?? "og.png",
  Astro.url.origin
).href;

const htmlLang = lang;
const langTags = getLangTag(lang);
---

<!doctype html>
<html lang={htmlLang} class={`${scrollSmooth && "scroll-smooth"}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Alternate language links -->
    <link
      rel="alternate"
      hreflang="en"
      href={canonicalURL.replace(`/${lang}/`, "/en/")}
    />
    <link
      rel="alternate"
      hreflang="es"
      href={canonicalURL.replace(`/${lang}/`, "/es/")}
    />
    <link
      rel="alternate"
      hreflang="x-default"
      href={canonicalURL.replace(`/${lang}/`, "/en/")}
    />

    <meta name="generator" content={Astro.generator} />

    <Schema
      item={{
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "@id": SITE.website,
        primaryImageOfPage: {
          "@context": "https://schema.org",
          "@type": "ImageObject",
          contentUrl: SITE.ogImage,
        },
        mainEntity: {
          "@context": "https://schema.org",
          "@type": "Person",
          name: SITE.author,
          alternateName: "Luis Salomón Muriel Urbina",
          description: t(lang, "seo.schemaDesc"),
          disambiguatingDescription: t(lang, "seo.schemaDisambig"),
          spouse: {
            "@type": "Person",
            name: "Natalia Rodríguez Triana",
            url: "https://www.linkedin.com/in/nat-innovacion/",
          },
          alumniOf: {
            "@type": "CollegeOrUniversity",
            name: ["Universidad de los Andes"],
            url: "https://uniandes.edu.co/",
          },
          knowsAbout: ["Entrepreneurship", "Technology", "Data Science"],
          url: SITE.website,
          image: SITE.website + SITE.ogImage,
          jobTitle: "Tech Director - NPD",
          worksFor: {
            "@type": "Organization",
            name: "R5",
            url: "https://www.grupor5.com/",
          },
          birthDate: "1991-01-01",
          birthPlace: {
            "@type": "Place",
            name: "Bogotá, Colombia",
          },
          sameAs: [
            "https://www.linkedin.com/in/smuriel/",
            "https://github.com/salomonMuriel",
            "https://steamcommunity.com/id/salomonk/",
          ],
        },
      }}
    />

    <slot name="head" />

    <!-- Google Tag Manager -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-061B5QE8B1"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-061B5QE8B1");
    </script>
    <!-- End Google Tag Manager -->

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === "es" ? "es_CO" : "en_US"} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <meta name="theme-color" content="" />

    {
      googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={googleSiteVerification}
        />
      )
    }

    <!-- Cal element-click embed code begins -->
    <script type="text/javascript">
      (function (C, A, L) {
        let p = function (a, ar) {
          a.q.push(ar);
        };
        let d = C.document;
        C.Cal =
          C.Cal ||
          function () {
            let cal = C.Cal;
            let ar = arguments;
            if (!cal.loaded) {
              cal.ns = {};
              cal.q = cal.q || [];
              d.head.appendChild(d.createElement("script")).src = A;
              cal.loaded = true;
            }
            if (ar[0] === L) {
              const api = function () {
                p(api, arguments);
              };
              const namespace = ar[1];
              api.q = api.q || [];
              if (typeof namespace === "string") {
                cal.ns[namespace] = cal.ns[namespace] || api;
                p(cal.ns[namespace], ar);
                p(cal, ["initNamespace", namespace]);
              } else p(cal, ar);
              return;
            }
            p(cal, ar);
          };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      Cal("init", "personal-site-intro-call", { origin: "https://cal.com" });
      Cal.ns["personal-site-intro-call"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });

      Cal("init", "30min", { origin: "https://cal.com" });
      Cal.ns["30min"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });

      Cal("init", "ai-tech-consulting", { origin: "https://cal.com" });
      Cal.ns["ai-tech-consulting"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });

      Cal("init", "data-science-consulting", { origin: "https://cal.com" });
      Cal.ns["data-science-consulting"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });

      Cal("init", "company-building-consulting", { origin: "https://cal.com" });
      Cal.ns["company-building-consulting"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });

      Cal("init", "mentorship", { origin: "https://cal.com" });
      Cal.ns["mentorship"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });

      Cal("init", "talks", { origin: "https://cal.com" });
      Cal.ns["talks"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });

      Cal("init", "talks-booking", { origin: "https://cal.com" });
      Cal.ns["talks-booking"]("ui", {
        styles: { branding: { brandColor: "#000000" } },
        hideEventTypeDetails: false,
        layout: "month_view",
      });
    </script>
    <!-- Cal element-click embed code ends -->

    <ViewTransitions />
  </head>
  <body>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)"
      ).matches;
      if (savedTheme) {
        document.documentElement.setAttribute("data-theme", savedTheme);
      } else if (prefersDark) {
        document.documentElement.setAttribute("data-theme", "dark");
      }
    </script>
    <slot />
  </body>
</html>
