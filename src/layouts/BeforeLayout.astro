---
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "./Layout.astro";
import type { CollectionEntry } from "astro:content";
import { t } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";

export interface Props {
  now: CollectionEntry<"now"> | CollectionEntry<"now-es">;
  lang?: Lang;
}

const { now, lang = defaultLang } = Astro.props;

const { Content } = await now.render();
---

<Layout title={`${SITE.title}`} lang={lang}>
  <Header activeNav="now" lang={lang} />
  <Breadcrumbs lang={lang} />
  <main id="main-content">
    <section id="now" class="prose mb-28 max-w-4xl prose-img:border-0">
      <h3>{t(lang, "before.updated")} {now.data.header}</h3>
      <p>
        {t(lang, "before.somethingPast")}{" "}
        <a href={`/${lang}/before`}>{t(lang, "before.seeOther")}</a>
      </p>
      <Content />
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
