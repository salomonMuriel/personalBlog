---
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "./Layout.astro";
import type { CollectionEntry } from "astro:content";
import Datetime from "@components/Datetime";
import { YouTube } from "astro-embed";
import { t } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";

export interface Props {
  presentation: CollectionEntry<"talks">;
  lang?: Lang;
}

const { presentation, lang = defaultLang } = Astro.props;
const { Content } = await presentation.render();
const html_path = `../../talks/${presentation.id.replace(".md", ".html")}`;
const pdf_path = `../../talks/${presentation.id.replace(".md", ".pdf")}`;
---

<Layout title={`${SITE.title}`} lang={lang}>
  <Header activeNav="talks" lang={lang} />
  <Breadcrumbs lang={lang} />
  <main id="main-content">
    <section class="prose mb-10 max-w-4xl">
      <h1>{presentation.data.title}</h1>
      <Datetime
        className="text-skin-base"
        pubDatetime={presentation.data.pubDatetime}
        modDatetime={presentation.data.modDatetime}
        lang={lang}
      />
      <p>{presentation.data.description}</p>
      {!presentation.data.marp && <Content />}
    </section>
    <section class="flex flex-col items-center">
      {
        presentation.data.youtube && (
          <YouTube
            class="w-full border-2 mb-8"
            id={presentation.data.youtube}
          />
        )
      }
      {
        presentation.data.marp && (
          <iframe src={html_path} class="h-64 w-full border-2 sm:h-96" />
        )
      }
      {
        presentation.data.embed_html && (
          <>
            <div class="hidden sm:block w-full">
              <iframe src={html_path} class="h-screen w-full border-2" />
            </div>
            <div class="block sm:hidden w-full border-2 border-skin-line rounded-md p-8 text-center">
              <p class="text-lg mb-4">{t(lang, "talks.mobileOnly")}</p>
              <p class="text-sm text-skin-base opacity-75">
                {t(lang, "talks.mobileDownload")}
              </p>
            </div>
          </>
        )
      }
      {
        presentation.data.embed_pdf && (
          <object
            data={pdf_path}
            type="application/pdf"
            class="h-64 w-full border-2 sm:h-96"
          >
            <span class="flex flex-col items-center justify-center align-middle text-center h-full">
              <p>{t(lang, "talks.pdfFallback")}</p>
              <br />
              <p>{t(lang, "talks.pdfDownloadHint")} 🔽</p>
            </span>
          </object>
        )
      }
      <div class="flex flex-wrap gap-4 justify-center mt-4 mb-8">
        {
          (presentation.data.marp || presentation.data.pdf) && (
            <a
              class="rounded-md border-2 border-skin-accent px-4 py-2 text-xl font-bold hover:bg-skin-accent hover:text-skin-base"
              href={pdf_path}
              download
            >
              {t(lang, "talks.downloadPdf")}
            </a>
          )
        }
        {
          presentation.data.embed_html && (
            <a
              class="rounded-md border-2 border-skin-accent px-4 py-2 text-xl font-bold hover:bg-skin-accent hover:text-skin-base"
              href={html_path}
              download
            >
              {t(lang, "talks.downloadHtml")}
            </a>
          )
        }
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
