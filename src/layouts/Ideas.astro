---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@config";
import { t, getCollectionName } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;

const ideas = await getCollection(getCollectionName(lang, "ideas"));

const sortedIdeas = ideas
  .sort((a, b) => b.data.importance - a.data.importance)
  .filter(({ data }) => !data.draft);
---

<Layout title={`${t(lang, "ideas.title")} | ${SITE.title}`} lang={lang}>
  <Header activeNav="ideas" lang={lang} />
  <Main pageTitle={t(lang, "ideas.title")} pageDesc={t(lang, "ideas.desc")}>
    <p class="prose text-skin-base text-lg w-full">
      {t(lang, "ideas.intro")}{" "}
      <a
        data-cal-link="salomuriel/personal-site-intro-call"
        data-cal-namespace="personal-site-intro-call"
        data-cal-config='{"layout":"month_view","theme":"dark"}'
        >{t(lang, "ideas.introLink")}</a
      >{" "}{t(lang, "ideas.introOutro")}
    </p>
    <hr class="my-8 border-skin-accent" />
    <ul class="list-disc">
      {
        sortedIdeas.map(({ data, id }) => (
          <li>
            <a
              class="inline-block text-xl font-medium text-skin-accent decoration-dashed underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0 underline"
              href={`/${lang}/ideas/${id}/`}
            >
              {data.title}
            </a>{" "}
            {data.current ? `- 🚀${t(lang, "ideas.currentlyWorking")}🚀` : ""}
          </li>
        ))
      }
    </ul>
  </Main>
  <Footer lang={lang} />
</Layout>
