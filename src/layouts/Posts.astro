---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Card from "@components/Card";
import { SITE } from "@config";
import { t } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";
import getReadingTime from "@utils/getReadingTime";

export interface Props {
  lang?: Lang;
  currentPage?: number;
  totalPages?: number;
  paginatedPosts?: any[];
}

const { lang = defaultLang } = Astro.props;

const blogCollection = lang === "es" ? "blog-es" : "blog";
const blogs = await getCollection(blogCollection);

const sortedBlogs = blogs
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  )
  .filter(({ data }) => !data.draft);
---

<Layout title={`${t(lang, "posts.title")} | ${SITE.title}`} lang={lang}>
  <Header activeNav="posts" lang={lang} />
  <Main pageTitle={t(lang, "posts.title")} pageDesc={t(lang, "posts.desc")}>
    <ul>
      {
        sortedBlogs.map(({ data, slug, body }) => (
          <Card
            href={`/${lang}/posts/${slug}/`}
            frontmatter={data}
            readingTime={`${getReadingTime(body)} ${t(lang, "readingTime.suffix")}`}
          />
        ))
      }
    </ul>
  </Main>
  <Footer lang={lang} />
</Layout>
