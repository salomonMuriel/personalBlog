---
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Card from "@components/Card.astro";
import { SITE } from "@config";
import { t, getLocalizedCollection } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";
import getReadingTime from "@utils/getReadingTime";

export interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;

const blogs = await getLocalizedCollection(lang, "blog");

const sortedBlogs = blogs
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  )
  .filter(({ data }) => !data.draft);
---

<Layout title={`${t(lang, "posts.title")} | ${SITE.title}`} lang={lang}>
  <Header activeNav="posts" lang={lang} />
  <Main pageTitle={t(lang, "posts.title")} pageDesc={t(lang, "posts.desc")}>
    <ul>
      {
        sortedBlogs.map(({ data, id, body }) => (
          <Card
            href={`/${lang}/posts/${id}/`}
            frontmatter={data}
            readingTime={`${getReadingTime(body ?? "")} ${t(lang, "readingTime.suffix")}`}
          />
        ))
      }
    </ul>
  </Main>
  <Footer lang={lang} />
</Layout>
