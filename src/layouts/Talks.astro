---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Card from "@components/Card";
import { SITE } from "@config";
import { t, getCollectionName } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;

const talks = await getCollection(getCollectionName(lang, "talks"));

const sortedTalks = talks
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  )
  .filter(({ data }) => !data.draft);
---

<Layout title={`${t(lang, "talks.title")} | ${SITE.title}`} lang={lang}>
  <Header activeNav="talks" lang={lang} />
  <Main pageTitle={t(lang, "talks.title")} pageDesc={t(lang, "talks.desc")}>
    <p class="prose text-skin-base text-lg">
      {t(lang, "talks.bookIntro")}{" "}
      <a
        data-cal-link="salomuriel/personal-site-intro-call"
        data-cal-namespace="personal-site-intro-call"
        data-cal-config='{"layout":"month_view","theme":"dark"}'
        >{t(lang, "talks.bookLink")}</a
      >{" "}{t(lang, "talks.bookOutro")}
    </p>
    <hr class="my-8 border-skin-accent" />
    <ul>
      {
        sortedTalks.map(({ data, id }) => (
          <Card href={`/${lang}/talks/${id}/`} frontmatter={data} />
        ))
      }
    </ul>
  </Main>
  <Footer lang={lang} />
</Layout>
