---
import "@fontsource/press-start-2p/400.css";
import "@fontsource/vt323/400.css";
import Sprites from "@components/cumple-35/Sprites.astro";
import GlobalFX from "@components/cumple-35/GlobalFX.astro";
import { SITE } from "@config";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL("/experimentos/cumple-35/", SITE.website).toString();
const ogImage = new URL("/cumple-35/og.png", SITE.website).toString();
---

<!doctype html>
<html lang="es" class="cumple-html">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#1a0b2e" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="noindex" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_CO" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="cumple-root">
    <div id="cumple-loader" class="cumple-loader" aria-hidden="true">
      <div class="loader-inner">
        <p class="loader-label">NOW LOADING</p>
        <div class="loader-bar">
          <div class="loader-fill"></div>
        </div>
        <p class="loader-pct"><span id="cumple-loader-pct">0</span>%</p>
        <p class="loader-hint">Press any key to continue...</p>
      </div>
    </div>
    <Sprites />
    <GlobalFX />
    <main id="cumple-main">
      <slot />
    </main>

    <script is:inline>
      (function () {
        const loader = document.getElementById("cumple-loader");
        const main = document.getElementById("cumple-main");
        const pctEl = document.getElementById("cumple-loader-pct");
        const fillEl = loader && loader.querySelector(".loader-fill");
        if (!loader || !main) return;

        const MIN_SHOW_MS = 900;
        const start = performance.now();
        let pct = 0;
        let ready = false;

        const fakeTick = setInterval(() => {
          const target = ready ? 100 : Math.min(92, pct + Math.random() * 7);
          pct += (target - pct) * 0.25;
          if (pctEl) pctEl.textContent = String(Math.round(pct));
          if (fillEl) fillEl.style.width = pct + "%";
          if (ready && pct >= 99.5) {
            clearInterval(fakeTick);
            if (pctEl) pctEl.textContent = "100";
            if (fillEl) fillEl.style.width = "100%";
          }
        }, 80);

        function finish() {
          const elapsed = performance.now() - start;
          const wait = Math.max(0, MIN_SHOW_MS - elapsed);
          setTimeout(() => {
            ready = true;
            setTimeout(() => {
              loader.classList.add("is-hidden");
              document.body.classList.add("cumple-ready");
              setTimeout(() => loader.remove(), 600);
            }, 220);
          }, wait);
        }

        const whenFonts =
          (document.fonts && document.fonts.ready) || Promise.resolve();
        const whenLoad = new Promise(resolve => {
          if (document.readyState === "complete") resolve();
          else window.addEventListener("load", () => resolve(), { once: true });
        });
        Promise.all([whenFonts, whenLoad]).then(finish);

        setTimeout(finish, 6000);
      })();
    </script>

    <style is:global>
      :root.cumple-html,
      body.cumple-root {
        --bg-deep: #1a0b2e;
        --bg-mid: #2a1746;
        --bg-panel: #3d1f5e;
        --gold: #f4c430;
        --gold-dark: #c89205;
        --gold-light: #ffe168;
        --cream: #f5e6d3;
        --pond: #4a9a5a;
        --pond-dark: #1e5631;
        --red: #ff3b3b;
        --pink: #ff6b9d;
        --cyan: #4dd4e7;
        --cork: #c89968;
        --cork-dark: #8b6841;
        --cork-deep: #5e4428;
        --paper: #fff8e4;
        --ink: #2a2015;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html.cumple-html {
        background: var(--bg-deep);
        image-rendering: pixelated;
        image-rendering: -moz-crisp-edges;
        image-rendering: crisp-edges;
        /* Prevent iOS momentum from chaining into the document and causing
           the "autoscroll up" glitch after fast scrolls. */
        overscroll-behavior-y: contain;
      }

      body.cumple-root {
        margin: 0;
        min-height: 100svh;
        background: var(--bg-deep);
        color: var(--cream);
        font-family: "VT323", monospace;
        font-size: 22px;
        line-height: 1.35;
        overflow-x: hidden;
        position: relative;
        -webkit-font-smoothing: none;
        -moz-osx-font-smoothing: grayscale;
        overscroll-behavior-y: contain;
      }

      body.cumple-root svg,
      body.cumple-root img,
      body.cumple-root canvas {
        image-rendering: pixelated;
      }

      body.cumple-root h1,
      body.cumple-root h2,
      body.cumple-root h3,
      body.cumple-root .display,
      body.cumple-root button,
      body.cumple-root .label {
        font-family: "Press Start 2P", "VT323", monospace;
        letter-spacing: 0.02em;
      }

      body.cumple-root a {
        color: var(--cyan);
        text-decoration: underline;
        text-underline-offset: 4px;
      }
      body.cumple-root a:hover {
        color: var(--gold-light);
      }

      #cumple-main {
        position: relative;
        z-index: 1;
        max-width: 760px;
        margin: 0 auto;
        padding: 56px 20px;
        opacity: 0;
        transition: opacity 400ms ease-out;
      }
      body.cumple-ready #cumple-main {
        opacity: 1;
      }

      .cumple-loader {
        position: fixed;
        inset: 0;
        z-index: 99999;
        background: var(--bg-deep);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 500ms ease-out;
      }
      .cumple-loader.is-hidden {
        opacity: 0;
        pointer-events: none;
      }
      .cumple-loader .loader-inner {
        width: min(420px, 86vw);
        text-align: center;
      }
      .cumple-loader .loader-label {
        font-family: "Press Start 2P", monospace;
        font-size: 12px;
        color: var(--cyan);
        letter-spacing: 0.18em;
        margin: 0 0 16px;
        animation: loader-blink 1.2s steps(2) infinite;
      }
      .cumple-loader .loader-bar {
        width: 100%;
        height: 20px;
        border: 3px solid var(--cream);
        background: var(--bg-deep);
        position: relative;
        overflow: hidden;
        image-rendering: pixelated;
      }
      .cumple-loader .loader-fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(
          to bottom,
          var(--gold-light) 0 25%,
          var(--gold) 25% 70%,
          var(--gold-dark) 70% 100%
        );
        transition: width 140ms linear;
      }
      .cumple-loader .loader-pct {
        margin: 12px 0 0;
        font-family: "Press Start 2P", monospace;
        font-size: 14px;
        color: var(--gold);
      }
      .cumple-loader .loader-hint {
        margin: 28px 0 0;
        font-family: "VT323", monospace;
        font-size: 18px;
        color: var(--cream);
        opacity: 0.65;
        animation: loader-blink 1.4s steps(2) infinite;
      }
      @keyframes loader-blink {
        50% {
          opacity: 0.35;
        }
      }

      @media (max-width: 480px) {
        #cumple-main {
          padding: 32px 16px;
        }
        body.cumple-root {
          font-size: 20px;
        }
      }

      .cumple-root .panel {
        background: var(--bg-panel);
        border: 4px solid var(--cream);
        box-shadow:
          0 0 0 4px var(--ink),
          8px 8px 0 0 var(--gold-dark);
        padding: 24px;
        margin-bottom: 40px;
        position: relative;
      }

      .cumple-root .panel-gold {
        background: var(--gold);
        color: var(--ink);
        border-color: var(--ink);
        box-shadow:
          0 0 0 4px var(--gold-dark),
          8px 8px 0 0 var(--ink);
      }

      .cumple-root .section-heading {
        font-size: clamp(18px, 4vw, 26px);
        color: var(--gold);
        margin: 48px 0 20px;
        text-shadow: 2px 2px 0 var(--ink);
      }

      .cumple-root .micro {
        font-family: "Press Start 2P", monospace;
        font-size: 10px;
        color: var(--cyan);
        letter-spacing: 0.1em;
      }

      .cumple-root .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 20px;
        font-family: "Press Start 2P", monospace;
        font-size: 12px;
        background: var(--red);
        color: var(--cream);
        border: 4px solid var(--ink);
        box-shadow: 4px 4px 0 0 var(--ink);
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        transition:
          transform 80ms linear,
          box-shadow 80ms linear;
      }
      .cumple-root .btn:active {
        transform: translate(4px, 4px);
        box-shadow: 0 0 0 0 var(--ink);
      }
      .cumple-root .btn-gold {
        background: var(--gold);
        color: var(--ink);
      }
      .cumple-root .btn[disabled] {
        opacity: 0.6;
        cursor: not-allowed;
      }

      .cumple-root .input,
      .cumple-root .textarea {
        width: 100%;
        background: var(--bg-deep);
        color: var(--cream);
        border: 3px solid var(--cream);
        padding: 10px 12px;
        font-family: "VT323", monospace;
        font-size: 20px;
        outline: none;
        transition:
          border-color 120ms linear,
          box-shadow 120ms linear;
      }
      .cumple-root .input:focus,
      .cumple-root .textarea:focus {
        border-color: var(--gold);
        box-shadow: 0 0 0 3px rgba(244, 196, 48, 0.35);
      }

      .cumple-root .pill-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      .cumple-root .pill {
        position: relative;
        cursor: pointer;
      }
      .cumple-root .pill input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }
      .cumple-root .pill span {
        display: inline-block;
        padding: 8px 14px;
        font-family: "Press Start 2P", monospace;
        font-size: 10px;
        background: var(--bg-deep);
        color: var(--cream);
        border: 3px solid var(--cream);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .cumple-root .pill input:checked + span {
        background: var(--gold);
        color: var(--ink);
        border-color: var(--ink);
        box-shadow: inset 2px 2px 0 0 var(--ink);
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </body>
</html>
