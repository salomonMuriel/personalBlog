---
import { LOGO_IMAGE, SITE } from "@config";
import Hr from "./Hr.astro";
import LinkButton from "./LinkButton.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getCollection } from "astro:content";
import { t, getCollectionName } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";
const { lightAndDarkMode } = SITE;

export interface Props {
  activeNav?:
    | "home"
    | "about"
    | "now"
    | "ideas"
    | "resources"
    | "uses"
    | "posts"
    | "talks"
    | "companies"
    | "explore"
    | "search"
    | "tags";
  lang?: Lang;
}

const { activeNav, lang = defaultLang } = Astro.props;

const posts = await getCollection(
  getCollectionName(lang, "blog"),
  ({ data }) => !data.draft
);
const talks = await getCollection(getCollectionName(lang, "talks"));

const prefix = `/${lang}`;
---

<header>
  <a id="skip-to-content" href="#main-content">{t(lang, "nav.skipToContent")}</a
  >
  <div class="nav-container">
    <div class="top-nav-wrap">
      <a href={`${prefix}/`} class="logo whitespace-nowrap">
        {
          LOGO_IMAGE.enable && (
            <img
              src={`/assets/${LOGO_IMAGE.svg ? "logo.svg" : "logo.png"}`}
              alt={SITE.title}
              width={LOGO_IMAGE.width}
              height={LOGO_IMAGE.height}
            />
          )
        }
      </a>
      <nav id="nav-menu">
        {
          /* Utility bar: always visible on mobile, inline after nav links on desktop */
        }
        <div class="nav-utilities">
          <LanguageSwitcher lang={lang} />
          <LinkButton
            href={`${prefix}/search/`}
            className={`focus-outline ${activeNav === "search" ? "active" : ""}`}
            ariaLabel={t(lang, "nav.search")}
            title={t(lang, "nav.search")}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="scale-125 sm:scale-100"
              ><path
                d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"
              ></path>
            </svg>
            <span class="sr-only">{t(lang, "nav.search")}</span>
          </LinkButton>
          {
            lightAndDarkMode && (
              <button
                id="theme-btn"
                class="focus-outline"
                title="Toggle Theme"
                aria-label="Toggle dark/light mode"
              >
                <svg xmlns="http://www.w3.org/2000/svg" id="moon-svg">
                  <path d="M20.742 13.045a8.088 8.088 0 0 1-2.077.271c-2.135 0-4.14-.83-5.646-2.336a8.025 8.025 0 0 1-2.064-7.723A1 1 0 0 0 9.73 2.034a10.014 10.014 0 0 0-4.489 2.582c-3.898 3.898-3.898 10.243 0 14.143a9.937 9.937 0 0 0 7.072 2.93 9.93 9.93 0 0 0 7.07-2.929 10.007 10.007 0 0 0 2.583-4.491 1.001 1.001 0 0 0-1.224-1.224zm-2.772 4.301a7.947 7.947 0 0 1-5.656 2.343 7.953 7.953 0 0 1-5.658-2.344c-3.118-3.119-3.118-8.195 0-11.314a7.923 7.923 0 0 1 2.06-1.483 10.027 10.027 0 0 0 2.89 7.848 9.972 9.972 0 0 0 7.848 2.891 8.036 8.036 0 0 1-1.484 2.059z" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" id="sun-svg">
                  <path d="M6.993 12c0 2.761 2.246 5.007 5.007 5.007s5.007-2.246 5.007-5.007S14.761 6.993 12 6.993 6.993 9.239 6.993 12zM12 8.993c1.658 0 3.007 1.349 3.007 3.007S13.658 15.007 12 15.007 8.993 13.658 8.993 12 10.342 8.993 12 8.993zM10.998 19h2v3h-2zm0-17h2v3h-2zm-9 9h3v2h-3zm17 0h3v2h-3zM4.219 18.363l2.12-2.122 1.415 1.414-2.12 2.122zM16.24 6.344l2.122-2.122 1.414 1.414-2.122 2.122zM6.342 7.759 4.22 5.637l1.415-1.414 2.12 2.122zm13.434 10.605-1.414 1.414-2.122-2.122 1.414-1.414z" />
                </svg>
              </button>
            )
          }
          <button
            class="hamburger-menu focus-outline border-2 p-2 sm:hidden"
            aria-label={t(lang, "nav.openMenu")}
            aria-expanded="false"
            aria-controls="menu-items"
          >
            {t(lang, "nav.menu")}
          </button>
        </div>

        <ul id="menu-items" class="display-none sm:flex">
          <li>
            <a href={`${prefix}/`} class={activeNav === "home" ? "active" : ""}>
              {t(lang, "nav.home")}
            </a>
          </li>
          <li>
            <a
              href={`${prefix}/about/`}
              class={activeNav === "about" ? "active" : ""}
            >
              {t(lang, "nav.about")}
            </a>
          </li>
          <li>
            <a
              href={`${prefix}/now/`}
              class={activeNav === "now" ? "active" : ""}
            >
              {t(lang, "nav.now")}
            </a>
          </li>
          <li>
            <a
              href={`${prefix}/companies/`}
              class={activeNav === "companies" ? "active" : ""}
            >
              {t(lang, "nav.companies")}
            </a>
          </li>
          {
            posts.length >= 1 && (
              <li>
                <a
                  href={`${prefix}/posts/`}
                  class={activeNav === "posts" ? "active" : ""}
                >
                  {t(lang, "nav.posts")}
                </a>
              </li>
            )
          }
          {
            talks.length >= 1 && (
              <li>
                <a
                  href={`${prefix}/talks/`}
                  class={activeNav === "talks" ? "active" : ""}
                >
                  {t(lang, "nav.talks")}
                </a>
              </li>
            )
          }

          {/* Mobile-only: flattened Explore items */}
          <li class="sm:hidden">
            <a
              href={`${prefix}/ideas/`}
              class={activeNav === "ideas" ? "active" : ""}
            >
              {t(lang, "nav.ideas")}
            </a>
          </li>
          <li class="sm:hidden">
            <a
              href={`${prefix}/resources/`}
              class={activeNav === "resources" ? "active" : ""}
            >
              {t(lang, "nav.resources")}
            </a>
          </li>
          <li class="sm:hidden">
            <a
              href={`${prefix}/uses/`}
              class={activeNav === "uses" ? "active" : ""}
            >
              {t(lang, "nav.uses")}
            </a>
          </li>

          {/* Desktop-only: Explore dropdown */}
          <li class="explore-dropdown hidden sm:flex sm:items-center">
            <button
              class={`explore-btn ${["ideas", "resources", "uses", "explore"].includes(activeNav ?? "") ? "active" : ""}`}
              aria-expanded="false"
              aria-haspopup="true"
            >
              {t(lang, "nav.explore")} &#9662;
            </button>
            <ul class="explore-menu">
              <li>
                <a
                  href={`${prefix}/ideas/`}
                  class={activeNav === "ideas" ? "active" : ""}
                >
                  {t(lang, "nav.ideas")}
                </a>
              </li>
              <li>
                <a
                  href={`${prefix}/resources/`}
                  class={activeNav === "resources" ? "active" : ""}
                >
                  {t(lang, "nav.resources")}
                </a>
              </li>
              <li>
                <a
                  href={`${prefix}/uses/`}
                  class={activeNav === "uses" ? "active" : ""}
                >
                  {t(lang, "nav.uses")}
                </a>
              </li>
            </ul>
          </li>
        </ul>
      </nav>
    </div>
  </div>
  <Hr />
</header>

<style>
  @reference "../styles/base.css";
  #skip-to-content {
    @apply absolute -top-full left-16 z-50 bg-skin-accent px-3 py-2 text-skin-inverted transition-all focus:top-4;
  }
  .nav-container {
    @apply mx-auto flex max-w-4xl flex-col items-center justify-between sm:flex-row;
  }
  .top-nav-wrap {
    @apply relative flex w-full items-start justify-between p-4 sm:items-center sm:py-8;
  }
  .logo {
    @apply absolute py-1 text-xl font-semibold sm:static sm:text-2xl;
  }
  nav {
    @apply flex w-full flex-col items-end sm:ml-2 sm:flex-row sm:items-center sm:justify-end sm:py-0;
  }

  /* Utility bar: always visible, appears first on mobile (top-right),
     ordered last on desktop (after nav links) */
  .nav-utilities {
    @apply flex items-center gap-2 sm:order-2 sm:ml-4 sm:gap-x-3;
  }
  .nav-utilities svg {
    @apply h-6 w-6 fill-skin-base;
  }

  .hamburger-menu {
    @apply p-2;
  }
  .hamburger-menu svg {
    @apply h-6 w-6 scale-125 fill-skin-base;
  }

  /* Nav links list: toggled on mobile, always visible on desktop */
  nav ul {
    @apply mt-4 w-full sm:order-1 sm:ml-0 sm:mt-0 sm:flex sm:w-auto sm:items-center sm:gap-x-3;
  }
  nav ul > li {
    @apply border-b border-skin-line sm:border-none;
  }
  nav ul > li a {
    @apply block w-full px-4 py-3 text-center font-medium hover:text-skin-accent sm:my-0 sm:px-1 sm:py-1;
  }
  nav a.active {
    @apply underline decoration-wavy decoration-2 underline-offset-4;
  }
  nav a.active svg {
    @apply fill-skin-accent;
  }
  nav button {
    @apply p-1;
  }
  nav button svg {
    @apply h-6 w-6 fill-skin-base hover:fill-skin-accent;
  }
  #theme-btn {
    @apply p-3 sm:p-1;
  }
  #theme-btn svg {
    @apply scale-125 hover:rotate-12 sm:scale-100;
  }
  .menu-icon line {
    @apply transition-opacity duration-75 ease-in-out;
  }
  .menu-icon .close {
    opacity: 0;
  }
  .menu-icon.is-active .line {
    @apply opacity-0;
  }
  .menu-icon.is-active .close {
    @apply opacity-100;
  }

  /* Explore dropdown (desktop only) */
  .explore-dropdown {
    @apply relative;
  }
  .explore-btn {
    @apply w-full px-4 py-3 text-center font-medium hover:text-skin-accent sm:my-0 sm:px-2 sm:py-1 cursor-pointer bg-transparent border-0 text-skin-base;
  }
  .explore-btn.active {
    @apply underline decoration-wavy decoration-2 underline-offset-4;
  }
  .explore-menu {
    @apply hidden flex-col border-2 border-skin-line bg-skin-fill rounded-lg overflow-hidden;
    @apply sm:absolute sm:top-full sm:left-1/2 sm:-translate-x-1/2 sm:mt-1 sm:min-w-[8rem] sm:z-50 sm:shadow-lg;
  }
  .explore-dropdown.open .explore-menu {
    @apply flex;
  }
  .explore-menu li {
    @apply border-0;
  }
  .explore-menu li a {
    @apply block w-full px-4 py-2 text-sm text-center hover:text-skin-accent hover:bg-skin-card;
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector(".hamburger-menu");
    const menuIcon = document.querySelector(".menu-icon");
    const menuItems = document.querySelector("#menu-items");

    menuBtn?.addEventListener("click", () => {
      const menuExpanded = menuBtn.getAttribute("aria-expanded") === "true";
      menuIcon?.classList.toggle("is-active");
      menuBtn.setAttribute("aria-expanded", menuExpanded ? "false" : "true");
      const isSpanish = window.location.pathname.startsWith("/es");
      menuBtn.setAttribute(
        "aria-label",
        menuExpanded
          ? isSpanish
            ? "Abrir menú"
            : "Open Menu"
          : isSpanish
            ? "Cerrar menú"
            : "Close Menu"
      );
      menuBtn.textContent = menuExpanded
        ? isSpanish
          ? "Menú"
          : "Menu"
        : isSpanish
          ? "Cerrar"
          : "Close";
      menuItems?.classList.toggle("display-none");
    });
  }

  toggleNav();

  function toggleTheme() {
    const themeBtn = document.querySelector("#theme-btn");
    themeBtn?.addEventListener("click", () => {
      const currentTheme = document.documentElement.getAttribute("data-theme");
      const newTheme = currentTheme === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);
    });
  }

  toggleTheme();

  function setupExploreDropdown() {
    const dropdown = document.querySelector(".explore-dropdown");
    const btn = dropdown?.querySelector(".explore-btn");

    btn?.addEventListener("click", e => {
      e.stopPropagation();
      dropdown?.classList.toggle("open");
      const expanded = dropdown?.classList.contains("open");
      btn.setAttribute("aria-expanded", expanded ? "true" : "false");
    });

    document.addEventListener("click", () => {
      dropdown?.classList.remove("open");
      btn?.setAttribute("aria-expanded", "false");
    });
  }

  setupExploreDropdown();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", () => {
    toggleNav();
    toggleTheme();
    setupExploreDropdown();
  });
</script>
