---
import Hr from "./Hr.astro";
import Socials from "./Socials.astro";
import { t } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import { defaultLang } from "@i18n/ui";

const currentYear = new Date().getFullYear();

export interface Props {
  noMarginTop?: boolean;
  lang?: Lang;
}

const { noMarginTop = false, lang = defaultLang } = Astro.props;
---

<footer class={`${noMarginTop ? "" : "mt-auto"}`}>
  <Hr noPadding />
  <div class="footer-wrapper">
    <Socials centered lang={lang} />
    <div class="copyright-wrapper">
      <span>{t(lang, "footer.copyright")} &#169; {currentYear}</span>
      <span class="separator">&nbsp;|&nbsp;</span>
      <span>{t(lang, "footer.allRights")}</span>
    </div>
  </div>
</footer>

<style>
  footer {
    @apply w-full;
  }
  .footer-wrapper {
    @apply flex flex-col items-center justify-between py-6 sm:flex-row-reverse;
  }
  .link-button {
    @apply my-1 p-2 hover:rotate-6;
  }
  .link-button svg {
    @apply scale-125;
  }
  .copyright-wrapper {
    @apply my-2 flex flex-col items-center whitespace-nowrap sm:flex-row;
  }
  .separator {
    @apply hidden sm:inline;
  }
</style>
