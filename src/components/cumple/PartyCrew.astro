---

<section class="panel">
  <div class="panel__tab">PARTY · MY CREW</div>
  <ul class="party__grid">
    {
      party.map(m => (
        <li class="member">
          <div class="member__sprite">
            <PixelSprite sprite={m.sprite} label={m.name} />
          </div>
          <span class="member__name">{m.name}</span>
          <span class="member__role">{m.role}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .party__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .member {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
    padding: 0.9rem 0.4rem 0.7rem;
    background: rgba(255, 217, 61, 0.06);
    border: 2px solid rgba(255, 217, 61, 0.35);
    transition: transform 0.15s ease;
  }
  .member:hover {
    transform: translateY(-4px);
    background: rgba(255, 217, 61, 0.12);
  }
  .member__sprite {
    width: 100%;
    max-width: 110px;
    aspect-ratio: 14 / 22;
    image-rendering: pixelated;
    filter: drop-shadow(3px 3px 0 rgba(0, 0, 0, 0.5));
  }
  .member__name {
    font-family: "Press Start 2P", monospace;
    font-size: 0.75rem;
    color: var(--gold);
    letter-spacing: 0.04em;
  }
  .member__role {
    font-family: "Press Start 2P", monospace;
    font-size: 0.45rem;
    color: var(--ink-dim);
    letter-spacing: 0.08em;
    line-height: 1.3;
  }
  @media (max-width: 520px) {
    .party__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
  }
</style>
