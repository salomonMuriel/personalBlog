---
const stats: { label: string; value: string }[] = [
  { label: "NIVEL", value: "35" },
  { label: "HP", value: "∞" },
  { label: "XP", value: "+35 años" },
  { label: "PARTY", value: "∞ panas" },
  { label: "EMPRESAS", value: "5" },
  { label: "GEMELOS", value: "2" },
  { label: "CERVEZAS", value: "∞" },
];
---

<section class="panel">
  <div class="panel__tab">CHARACTER SHEET</div>
  <ul class="stats__grid">
    {
      stats.map(s => (
        <li>
          <span class="stat__label">{s.label}</span>
          <span class="stat__value">{s.value}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .stats__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0.75rem;
  }
  .stats__grid li {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 0.75rem;
    background: rgba(255, 217, 61, 0.08);
    border-left: 4px solid var(--gold);
  }
  .stat__label {
    font-family: "Press Start 2P", monospace;
    font-size: 0.6rem;
    color: var(--ink-dim);
    letter-spacing: 0.08em;
  }
  .stat__value {
    font-size: 1.8rem;
    color: var(--gold);
    line-height: 1;
    margin-top: 4px;
  }
</style>
