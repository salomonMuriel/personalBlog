---
const formUrl =
  "https://docs.google.com/forms/d/e/1FAIpQLSdeTMgbheBf_ZoV3uRq3dlfQORJpcM1hNHtNZ-qAGRQ7cv5ww/viewform?embedded=true";
const whatsappUrl =
  "https://wa.me/573132465100?text=Voy%20a%20tu%20cumple%2035%20%F0%9F%8E%89";
---

<section class="panel rsvp" id="rsvp">
  <div class="panel__tab">RSVP · PRESS START</div>
  <p class="rsvp__prompt">
    ¿Te apareces? Cuéntame si vas y si traes +1. ¡No me dejes solo en el boss
    fight!
  </p>

  <div class="rsvp__frame">
    <iframe
      src={formUrl}
      width="100%"
      height="832"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      title="RSVP fiesta Salo 35"
      loading="lazy"
    >
      Cargando…
    </iframe>
  </div>

  <p class="rsvp__fallback">
    ¿No te carga? Mándame un <a href={whatsappUrl}>WhatsApp</a> y listo.
  </p>
</section>

<style>
  .rsvp__prompt {
    margin: 0 0 1rem;
  }
  .rsvp__frame {
    background: rgba(244, 238, 255, 0.97);
    border: var(--pixel) solid var(--green);
    padding: 4px;
  }
  .rsvp__frame iframe {
    display: block;
    width: 100%;
    border: 0;
    background: #fff;
  }
  .rsvp__fallback {
    margin-top: 1rem;
    font-size: 1rem;
    color: var(--ink-dim);
    text-align: center;
  }
</style>
