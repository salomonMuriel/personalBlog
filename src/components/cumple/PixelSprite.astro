---
import type { Sprite } from "./sprite";

export interface Props {
  sprite: Sprite;
  label: string;
}

const { sprite, label } = Astro.props;
---

<svg
  viewBox={`0 0 ${sprite.w} ${sprite.h}`}
  shape-rendering="crispEdges"
  role="img"
  aria-label={label}
>
  <title>{label}</title>
  {
    sprite.cells.map(c => (
      <rect x={c.x} y={c.y} width="1" height="1" fill={c.c} />
    ))
  }
</svg>

<style>
  svg {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
