---
import FrogMascot from "./FrogMascot.astro";
---

<header class="hero">
  <p class="tag-blink">● PRESS START</p>
  <h1 class="title">
    <span class="title-row">NIVEL 35</span>
    <span class="title-row">DESBLOQUEADO</span>
  </h1>
  <FrogMascot />
  <p class="subtitle">&gt; Iniciando fiesta... Saturday 25.04.26 · 19:00</p>
</header>

<style>
  .hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .tag-blink {
    font-family: "Press Start 2P", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--green);
    animation: blink 1.1s steps(2, end) infinite;
    margin: 0;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
  .title {
    font-family: "Press Start 2P", monospace;
    font-size: clamp(1.4rem, 6vw, 2.6rem);
    line-height: 1.15;
    margin: 0;
    color: var(--gold);
    text-shadow:
      4px 4px 0 var(--magenta),
      8px 8px 0 rgba(0, 0, 0, 0.45);
  }
  .title-row {
    display: block;
  }
  .subtitle {
    font-family: "Press Start 2P", monospace;
    font-size: 0.75rem;
    color: var(--ink-dim);
    margin: 0.25rem 0 0;
    letter-spacing: 0.05em;
  }
  @media (prefers-reduced-motion: reduce) {
    .tag-blink {
      animation: none;
    }
  }
</style>
