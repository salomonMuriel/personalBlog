---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card.astro";
import HeroSection from "@components/home/HeroSection.astro";
import AboutSection from "@components/home/AboutSection.astro";
import ConsultancySection from "@components/home/ConsultancySection.astro";
import SpeakingSection from "@components/home/SpeakingSection.astro";
import getPosts from "@utils/getPosts";
import getReadingTime from "@utils/getReadingTime";
import { t, getLocalizedCollection } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

export interface Props {
  lang: Lang;
  canonicalURL?: string;
}

const { lang, canonicalURL } = Astro.props;

const posts = await getLocalizedCollection(lang, "blog");
const nows = await getLocalizedCollection(lang, "now");
const talks = await getLocalizedCollection(lang, "talks");
const sortedPosts = getPosts(posts);
const sortedNows = nows.sort(
  (a, b) => Number(b.data.date) - Number(a.data.date)
);
const sortedTalks = talks.sort(
  (a, b) => Number(b.data.pubDatetime) - Number(a.data.pubDatetime)
);
const latestTalk = sortedTalks[0];
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout lang={lang} canonicalURL={canonicalURL}>
  <slot name="head" slot="head" />
  <Header lang={lang} />
  <main id="main-content">
    <HeroSection lang={lang} />

    <Hr />
    <AboutSection lang={lang} />

    <Hr />
    <ConsultancySection lang={lang} />

    <Hr />
    <SpeakingSection lang={lang} latestTalk={latestTalk} />

    <Hr />

    {
      nows.length > 0 && (
        <>
          <section id="now">
            <h2>{t(lang, "now.title")}</h2>
            {t(lang, "now.subtitle")}
            <h3 class="text-lg font-medium text-skin-accent">
              {t(lang, "now.latestUpdate")}
            </h3>
            <ul class="prose">
              <li>
                <a
                  href={`/${lang}/now`}
                  class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                >
                  {sortedNows[0].data.header}
                </a>
              </li>
            </ul>
            <h3 class="text-lg font-medium text-skin-accent">
              {t(lang, "now.previous")}
            </h3>
            <ul class="prose">
              {sortedNows.map(
                ({ data, id }, index) =>
                  index < 4 &&
                  index > 0 && (
                    <li>
                      <a
                        href={`/${lang}/before/${id}`}
                        class="text-lg font-medium decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline focus-visible:underline-offset-0"
                      >
                        {data.header}
                      </a>
                    </li>
                  )
              )}
            </ul>
            <div class="all-posts-btn-wrapper">
              <LinkButton href={`/${lang}/before/`}>
                {t(lang, "now.allPrevious")}
                <svg xmlns="http://www.w3.org/2000/svg">
                  <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
                </svg>
              </LinkButton>
            </div>
          </section>
          <Hr />
        </>
      )
    }

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured">
            <h2>{t(lang, "posts.featured")}</h2>
            <ul>
              {featuredPosts.map(({ data, id, body }) => (
                <Card
                  href={`/${lang}/posts/${id}/`}
                  frontmatter={data}
                  secHeading={false}
                  readingTime={`${getReadingTime(body)} ${t(lang, "readingTime.suffix")}`}
                  lang={lang}
                />
              ))}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <h2>{t(lang, "posts.recent")}</h2>
          <ul>
            {recentPosts.map(
              ({ data, id, body }, index) =>
                index < 4 && (
                  <Card
                    href={`/${lang}/posts/${id}/`}
                    frontmatter={data}
                    secHeading={false}
                    readingTime={`${getReadingTime(body)} ${t(lang, "readingTime.suffix")}`}
                    lang={lang}
                  />
                )
            )}
          </ul>
        </section>
      )
    }

    {
      sortedPosts.length > 0 && (
        <div class="all-posts-btn-wrapper">
          <LinkButton href={`/${lang}/posts/`}>
            {t(lang, "posts.allPosts")}
            <svg xmlns="http://www.w3.org/2000/svg">
              <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
            </svg>
          </LinkButton>
        </div>
      )
    }
  </main>

  <Footer lang={lang} />
</Layout>

<style>
  @reference "../styles/base.css";
  #featured,
  #recent-posts,
  #now {
    @apply pb-6 pt-6;
  }
  #featured h2,
  #recent-posts h2,
  #now h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .all-posts-btn-wrapper {
    @apply my-4 text-center;
  }
</style>
