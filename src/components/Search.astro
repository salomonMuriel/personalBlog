---
import type { CollectionEntry } from "astro:content";
import type { Lang } from "@i18n/ui";
import Card from "./Card.astro";

export type SearchItem = {
  title: string;
  description: string;
  data: CollectionEntry<"blog">["data"];
  id: string;
};

interface Props {
  searchList: SearchItem[];
  lang?: Lang;
}

const { searchList, lang = "en" } = Astro.props;

const placeholder =
  lang === "es" ? "Busca lo que quieras..." : "Search for anything...";
const searchLabel = lang === "es" ? "Buscar" : "Search";
---

<label class="relative block">
  <span class="absolute inset-y-0 left-0 flex items-center pl-2 opacity-75">
    <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path
        d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"
      ></path>
    </svg>
    <span class="sr-only">{searchLabel}</span>
  </span>
  <input
    id="search-input"
    class="block w-full rounded border border-skin-fill border-skin-fill/40 bg-skin-fill py-3 pl-10 pr-3 placeholder:italic placeholder:text-skin-base/75 focus:border-skin-accent focus:outline-none"
    placeholder={placeholder}
    type="text"
    name="search"
    autocomplete="off"
  />
</label>

<div id="search-status" class="mt-8 hidden"></div>

<ul id="search-results">
  {/* All cards rendered server-side, hidden by default, shown by JS */}
  {
    searchList.map(item => (
      <div
        class="search-card hidden"
        data-title={item.title.toLowerCase()}
        data-description={item.description.toLowerCase()}
      >
        <Card
          href={`/${lang}/posts/${item.id}/`}
          frontmatter={item.data}
          lang={lang}
        />
      </div>
    ))
  }
</ul>

<script>
  import Fuse from "fuse.js";

  function initSearch() {
    const input = document.getElementById("search-input") as HTMLInputElement;
    const status = document.getElementById("search-status")!;
    const cards = document.querySelectorAll<HTMLElement>(".search-card");
    if (!input || !cards.length) return;

    const isEs = window.location.pathname.startsWith("/es");

    const items = Array.from(cards).map((card, i) => ({
      title: card.dataset.title || "",
      description: card.dataset.description || "",
      index: i,
    }));

    const fuse = new Fuse(items, {
      keys: ["title", "description"],
      includeMatches: true,
      minMatchCharLength: 2,
      threshold: 0.5,
    });

    // Restore from URL
    const searchStr = new URLSearchParams(window.location.search).get("q");
    if (searchStr) {
      input.value = searchStr;
      doSearch(searchStr);
    }

    input.addEventListener("input", () => doSearch(input.value));

    function doSearch(query: string) {
      // Update URL
      if (query.length > 0) {
        const params = new URLSearchParams(window.location.search);
        params.set("q", query);
        history.replaceState(
          history.state,
          "",
          window.location.pathname + "?" + params.toString()
        );
      } else {
        history.replaceState(history.state, "", window.location.pathname);
      }

      // Hide all
      cards.forEach(c => c.classList.add("hidden"));

      if (query.length <= 1) {
        status.classList.add("hidden");
        return;
      }

      const results = fuse.search(query);

      const foundText = isEs ? "Se encontraron" : "Found";
      const resultText =
        results.length === 1
          ? isEs
            ? "resultado"
            : "result"
          : isEs
            ? "resultados"
            : "results";
      const forText = isEs ? "para" : "for";

      status.textContent = `${foundText} ${results.length} ${resultText} ${forText} '${query}'`;
      status.classList.remove("hidden");

      results.forEach(({ item }) => {
        cards[item.index].classList.remove("hidden");
      });
    }
  }

  initSearch();
  document.addEventListener("astro:after-swap", initSearch);
</script>
