---
// 5.6 Inventario — 7 slots
const items = [
  {
    sprite: "beer",
    box: "0 0 24 32",
    name: "POLA FRÍA",
    flavor: "Restaura +10 HP y +5 CHA. Stack: ∞",
  },
  {
    sprite: "controller",
    box: "0 0 32 16",
    name: "16-BIT PAD",
    flavor: "Arma favorita. DMG épico",
  },
  {
    sprite: "hammer",
    box: "0 0 20 20",
    name: "HERRAMIENTAS",
    flavor: "+5 a crafting. Indispensable",
  },
  {
    sprite: "printer3d",
    box: "0 0 32 32",
    name: "IMPRESORA 3D",
    flavor: "Crafting legendario. 24h cooldown",
  },
  {
    sprite: "gemelos",
    box: "",
    name: "GEMELOS",
    flavor: "Compañeros legendarios. -10 a sleep",
  },
  {
    sprite: "laptop",
    box: "0 0 32 24",
    name: "LAPTOP",
    flavor: "Item clave de clase Maker",
  },
  {
    sprite: "potion",
    box: "0 0 16 24",
    name: "POCIÓN PERRENQUE",
    flavor: "+20 a todos los stats por 8h. Solo Colombia 🇨🇴",
  },
];
---

<section class="inv">
  <h2 class="section-heading">&gt; INVENTARIO</h2>
  <p class="micro sub">ITEMS EQUIPADOS</p>
  <div class="grid">
    {
      items.map(it => (
        <div class="slot">
          <div class="art">
            {it.sprite === "gemelos" ? (
              <div class="twin">
                <svg viewBox="0 0 24 32" aria-hidden="true">
                  <use href="#sprite-franco" />
                </svg>
                <svg viewBox="0 0 24 32" aria-hidden="true">
                  <use href="#sprite-luca" />
                </svg>
              </div>
            ) : (
              <svg viewBox={it.box} aria-hidden="true">
                <use href={`#${it.sprite}`} />
              </svg>
            )}
          </div>
          <h3 class="nm">{it.name}</h3>
          <p class="fl">{it.flavor}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .sub {
    margin: 0 0 20px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media (min-width: 620px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .slot {
    background: var(--bg-panel);
    border: 3px solid var(--cream);
    box-shadow:
      inset 0 0 0 2px var(--ink),
      4px 4px 0 0 var(--gold-dark);
    padding: 14px 12px;
    text-align: center;
    min-height: 170px;
    display: flex;
    flex-direction: column;
  }
  .art {
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
  }
  .art svg {
    width: auto;
    height: 64px;
  }
  .twin {
    display: flex;
    gap: 6px;
  }
  .twin svg {
    height: 56px;
  }
  .nm {
    margin: 0 0 6px;
    font-family: "Press Start 2P", monospace;
    font-size: 10px;
    color: var(--gold);
    line-height: 1.4;
  }
  .fl {
    margin: auto 0 0;
    font-family: "VT323", monospace;
    font-size: 16px;
    color: var(--cream);
    line-height: 1.2;
  }
</style>
