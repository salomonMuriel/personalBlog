---
// 6.5 Flappy Rana — modal canvas minigame. Opens on CustomEvent('frog:invite').
---

<div
  id="flappy-modal"
  class="flappy"
  hidden
  aria-modal="true"
  role="dialog"
  aria-label="Flappy Rana"
>
  <div class="flappy-inner panel">
    <header class="flappy-head">
      <h2>FLAPPY RANA</h2>
      <button type="button" class="close" id="flappy-close" aria-label="Cerrar"
        >✕</button
      >
    </header>

    <canvas id="flappy-canvas" width="360" height="540"></canvas>

    <footer class="flappy-foot">
      <div class="scores">
        <span class="lbl">SCORE</span><span class="val" id="flappy-score"
          >0</span
        >
        <span class="lbl">BEST</span><span class="val" id="flappy-best">0</span>
      </div>
      <p class="tip">TAP / CLICK / ESPACIO para saltar</p>
      <button type="button" class="btn btn-gold" id="flappy-start"
        >▶ JUGAR</button
      >
    </footer>
  </div>
</div>

<style>
  .flappy {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(26, 11, 46, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .flappy[hidden] {
    display: none;
  }
  .flappy-inner {
    max-width: 420px;
    width: 100%;
    margin: 0;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .flappy-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .flappy-head h2 {
    margin: 0;
    font-family: "Press Start 2P", monospace;
    font-size: 14px;
    color: var(--gold);
    letter-spacing: 0.05em;
  }
  .close {
    background: transparent;
    color: var(--cream);
    border: 3px solid var(--cream);
    width: 34px;
    height: 34px;
    font-family: "Press Start 2P", monospace;
    font-size: 11px;
    cursor: pointer;
  }

  #flappy-canvas {
    display: block;
    width: 100%;
    max-width: 360px;
    aspect-ratio: 2 / 3;
    margin: 0 auto;
    background: #0a5370;
    border: 4px solid var(--cream);
    box-shadow: inset 0 0 0 3px var(--ink);
    touch-action: none;
    -webkit-tap-highlight-color: transparent;
    cursor: pointer;
  }

  .flappy-foot {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }
  .scores {
    display: grid;
    grid-template-columns: auto auto auto auto;
    gap: 6px 12px;
    font-family: "Press Start 2P", monospace;
    font-size: 11px;
  }
  .scores .lbl {
    color: var(--cyan);
  }
  .scores .val {
    color: var(--gold-light);
  }
  .tip {
    margin: 0;
    font-family: "VT323", monospace;
    font-size: 18px;
    opacity: 0.8;
  }
</style>

<script>
  // Adapted from https://gist.github.com/CoolKan/a37cb36fc76a737494fb07fab213d9f1
  const modal = document.getElementById("flappy-modal") as HTMLElement | null;
  const closeBtn = document.getElementById("flappy-close");
  const startBtn = document.getElementById(
    "flappy-start"
  ) as HTMLButtonElement | null;
  const scoreEl = document.getElementById("flappy-score");
  const bestEl = document.getElementById("flappy-best");
  const canvas = document.getElementById(
    "flappy-canvas"
  ) as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d") ?? null;

  if (modal && canvas && ctx) {
    ctx.imageSmoothingEnabled = false;

    const frogImg = new Image();
    frogImg.src = "/cumple-35/frog.png";

    const W = canvas.width;
    const H = canvas.height;

    // game settings
    const gravity = 0.4;
    const speed = 2.6;
    const size: [number, number] = [40, 40];
    const jump = -7;
    const cTenth = W / 10;

    // pipe settings
    const pipeWidth = 60;
    const pipeGap = 160;
    const pipeLoc = () =>
      Math.random() * (H - (pipeGap + pipeWidth) - pipeWidth) + pipeWidth;

    let gamePlaying = false;
    let gameOver = false;
    let index = 0;
    let bestScore = Number(localStorage.getItem("flappy-rana-best") || 0);
    let currentScore = 0;
    let flight = jump;
    let flyHeight = H / 2 - size[1] / 2;
    let pipes: [number, number][] = [];
    let rafId = 0;

    if (bestEl) bestEl.textContent = String(bestScore);

    function setup() {
      currentScore = 0;
      flight = jump;
      flyHeight = H / 2 - size[1] / 2;
      pipes = Array(3)
        .fill(0)
        .map(
          (_, i) =>
            [W + i * (pipeGap + pipeWidth * 3), pipeLoc()] as [number, number]
        );
      gameOver = false;
      if (scoreEl) scoreEl.textContent = "0";
    }

    function drawBackground() {
      if (!ctx) return;
      ctx.fillStyle = "#0a5370";
      ctx.fillRect(0, 0, W, H);
      ctx.fillStyle = "#1a6a8a";
      for (let y = 0; y < H; y += 8) {
        if ((y / 8) % 2 === 0) ctx.fillRect(0, y, W, 2);
      }
      ctx.fillStyle = "#f5e6d3";
      for (let i = 0; i < 18; i++) {
        const sx = (i * 97 + index * 0.5) % W;
        const sy = (i * 53) % (H - 80);
        ctx.fillRect(Math.floor(sx), sy, 2, 2);
      }
      // ground
      ctx.fillStyle = "#1e5631";
      ctx.fillRect(0, H - 30, W, 30);
      ctx.fillStyle = "#4a9a5a";
      ctx.fillRect(0, H - 30, W, 4);
    }

    function drawPipe(x: number, topH: number) {
      if (!ctx) return;
      // top pipe
      ctx.fillStyle = "#f4c430";
      ctx.fillRect(x, 0, pipeWidth, topH);
      ctx.fillStyle = "#2a2015";
      ctx.fillRect(x - 3, topH - 10, pipeWidth + 6, 10);
      ctx.fillStyle = "#ffe168";
      ctx.fillRect(x + 4, 0, 4, topH - 10);
      // bottom pipe
      const bottomY = topH + pipeGap;
      ctx.fillStyle = "#f4c430";
      ctx.fillRect(x, bottomY, pipeWidth, H - bottomY);
      ctx.fillStyle = "#2a2015";
      ctx.fillRect(x - 3, bottomY, pipeWidth + 6, 10);
      ctx.fillStyle = "#ffe168";
      ctx.fillRect(x + 4, bottomY + 10, 4, H - bottomY - 10);
    }

    function render() {
      if (!ctx) return;
      index++;
      drawBackground();

      if (gamePlaying) {
        pipes.forEach(pipe => {
          pipe[0] -= speed;
          drawPipe(pipe[0], pipe[1]);

          if (pipe[0] <= -pipeWidth) {
            currentScore++;
            bestScore = Math.max(bestScore, currentScore);
            if (scoreEl) scoreEl.textContent = String(currentScore);
            if (bestEl) bestEl.textContent = String(bestScore);
            localStorage.setItem("flappy-rana-best", String(bestScore));
            pipes = [
              ...pipes.slice(1),
              [pipes[pipes.length - 1][0] + pipeGap + pipeWidth, pipeLoc()] as [
                number,
                number,
              ],
            ];
          }

          const hitX =
            pipe[0] <= cTenth + size[0] && pipe[0] + pipeWidth >= cTenth;
          const hitY =
            pipe[1] > flyHeight || pipe[1] + pipeGap < flyHeight + size[1];
          if (hitX && hitY) {
            gamePlaying = false;
            gameOver = true;
            (window as any).__cumpleSfx?.ribbit?.();
          }
        });
      }

      if (gamePlaying) {
        if (frogImg.complete)
          ctx.drawImage(frogImg, cTenth, flyHeight, size[0], size[1]);
        flight += gravity;
        flyHeight = Math.min(flyHeight + flight, H - size[1] - 30);
        if (flyHeight >= H - size[1] - 30) {
          gamePlaying = false;
          gameOver = true;
          (window as any).__cumpleSfx?.ribbit?.();
        }
      } else {
        if (frogImg.complete)
          ctx.drawImage(
            frogImg,
            W / 2 - size[0] / 2,
            H / 2 - size[1] / 2,
            size[0],
            size[1]
          );
        if (!gameOver) {
          ctx.fillStyle = "#ffe168";
          ctx.font = "14px 'Press Start 2P', monospace";
          ctx.textAlign = "center";
          ctx.fillText("TAP / ESPACIO", W / 2, H / 2 + 60);
          ctx.textAlign = "left";
        }
      }

      // score HUD
      if (gamePlaying || gameOver) {
        ctx.fillStyle = "rgba(0,0,0,0.4)";
        ctx.fillRect(10, 10, 84, 28);
        ctx.fillStyle = "#ffe168";
        ctx.font = "16px 'Press Start 2P', monospace";
        ctx.textBaseline = "top";
        ctx.textAlign = "left";
        ctx.fillText(String(currentScore), 18, 16);
      }

      if (gameOver) {
        ctx.fillStyle = "rgba(26, 11, 46, 0.85)";
        ctx.fillRect(0, H / 2 - 60, W, 120);
        ctx.fillStyle = "#ff3b3b";
        ctx.font = "18px 'Press Start 2P', monospace";
        ctx.textAlign = "center";
        ctx.fillText("GAME OVER", W / 2, H / 2 - 20);
        ctx.fillStyle = "#f5e6d3";
        ctx.font = "10px 'Press Start 2P', monospace";
        ctx.fillText("TAP para reintentar", W / 2, H / 2 + 10);
        ctx.textAlign = "left";
      }

      rafId = requestAnimationFrame(render);
    }

    function flap() {
      if (gameOver) {
        setup();
        gamePlaying = true;
        flight = jump;
        (window as any).__cumpleSfx?.coin?.();
        return;
      }
      if (!gamePlaying) {
        setup();
        gamePlaying = true;
      }
      flight = jump;
      (window as any).__cumpleSfx?.coin?.();
    }

    function open() {
      if (!modal) return;
      modal.hidden = false;
      setup();
      gamePlaying = false;
      gameOver = false;
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(render);
    }
    function close() {
      if (!modal) return;
      modal.hidden = true;
      gamePlaying = false;
      cancelAnimationFrame(rafId);
    }

    window.addEventListener("frog:invite", open);
    closeBtn?.addEventListener("click", close);
    startBtn?.addEventListener("click", () => {
      setup();
      gamePlaying = true;
      flight = jump;
      (window as any).__cumpleSfx?.coin?.();
      startBtn?.blur();
    });

    canvas.addEventListener("pointerdown", e => {
      e.preventDefault();
      flap();
    });
    window.addEventListener("keydown", e => {
      if (modal.hidden) return;
      if (e.key === " " || e.key === "ArrowUp" || e.key === "w") {
        e.preventDefault();
        e.stopPropagation();
        flap();
      }
      if (e.key === "Escape") close();
    });

    setup();
  }
</script>
