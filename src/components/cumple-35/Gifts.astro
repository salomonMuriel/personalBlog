---
// 5.10 Regalos
const missions = [
  "Invítame una pola 🍺",
  "Tomémonos una foto juntos 📸",
  "Escríbeme algo en una servilleta 📝",
  "Déjame una predicción o consejo pa' mi año 35 🔮",
  "Un chiste malo. Obligatorio. 😬",
];
---

<section class="gifts">
  <h2 class="section-heading center">&gt; ¿REGALOS?</h2>
  <div class="panel panel-gold">
    <p class="big">CERO. NADA. NO TRAIGAN NADA. PORFA. 🙏</p>
    <p class="lead">
      Pero si de verdad insisten, acá van las misiones opcionales:
    </p>
    <ol class="missions">
      {missions.map(m => <li>{m}</li>)}
    </ol>
  </div>
</section>

<style>
  .center {
    text-align: center;
  }
  .big {
    margin: 0 0 14px;
    font-family: "Press Start 2P", monospace;
    font-size: clamp(12px, 2.6vw, 16px);
    color: var(--ink);
    line-height: 1.5;
    text-align: center;
  }
  .lead {
    font-family: "VT323", monospace;
    font-size: 20px;
    color: var(--ink);
    margin: 0 0 14px;
    text-align: center;
  }
  .missions {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    counter-reset: mission;
  }
  .missions li {
    counter-increment: mission;
    font-family: "VT323", monospace;
    font-size: 22px;
    color: var(--ink);
    padding-left: 38px;
    position: relative;
  }
  .missions li::before {
    content: counter(mission, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0;
    font-family: "Press Start 2P", monospace;
    font-size: 12px;
    color: var(--red);
  }
</style>
