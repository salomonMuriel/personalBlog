---
// 5.8 Evidencia — 6 polaroids. TODO: replace placeholder with real photos in /public/cumple-35/polaroids/
const captions = [
  {
    src: "/cumple-35/polaroids/01.png",
    text: "el parche original 📸",
    rot: -4,
  },
  { src: "/cumple-35/polaroids/02.png", text: "Nata & yo · 2018", rot: 3 },
  { src: "/cumple-35/polaroids/03.png", text: "Franco + Luca 👶👶", rot: -2 },
  { src: "/cumple-35/polaroids/04.png", text: "la primera locura", rot: 5 },
  { src: "/cumple-35/polaroids/05.png", text: "Ignia, allá vamos 🔥", rot: -3 },
  {
    src: "/cumple-35/polaroids/06.png",
    text: "una pola con ustedes 🍺",
    rot: 2,
  },
];
---

<section class="pol">
  <h2 class="section-heading">&gt; EVIDENCIA</h2>
  <div class="grid">
    {
      captions.map((p, i) => (
        <figure class="pic" style={`--rot: ${p.rot}deg; --i: ${i}`}>
          <div class="photo">
            <img
              src={p.src}
              alt={p.text}
              loading="lazy"
              onerror="this.style.display='none'; this.parentElement.classList.add('missing');"
            />
            <div class="ph-fallback" aria-hidden="true">
              <span class="ph-icon">📷</span>
              <span class="ph-text">TODO: foto</span>
            </div>
          </div>
          <figcaption>{p.text}</figcaption>
        </figure>
      ))
    }
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }
  @media (min-width: 620px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .pic {
    margin: 0;
    padding: 10px 10px 14px;
    background: var(--paper);
    color: var(--ink);
    border: 3px solid var(--ink);
    box-shadow: 4px 6px 0 0 var(--cork-deep);
    transform: rotate(var(--rot));
    transition:
      transform 200ms ease-out,
      box-shadow 200ms ease-out;
    position: relative;
  }
  .pic:hover {
    transform: rotate(0deg) translateY(-3px) scale(1.04);
    z-index: 2;
    box-shadow: 6px 10px 0 0 var(--cork-deep);
  }
  .photo {
    aspect-ratio: 1 / 1;
    background: var(--bg-deep);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ph-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: var(--bg-panel);
    color: var(--cream);
  }
  .photo.missing .ph-fallback {
    z-index: 1;
  }
  .photo:not(.missing) .ph-fallback {
    display: none;
  }
  .ph-icon {
    font-size: 32px;
  }
  .ph-text {
    font-family: "Press Start 2P", monospace;
    font-size: 8px;
    letter-spacing: 0.1em;
  }
  figcaption {
    margin-top: 10px;
    font-family: "VT323", monospace;
    font-size: 18px;
    color: var(--ink);
    text-align: center;
  }
</style>

<script>
  // Hide fallback once image loads
  document.querySelectorAll<HTMLImageElement>(".pol img").forEach(img => {
    if (img.complete && img.naturalWidth > 0) {
      // loaded from cache; nothing to do
    } else {
      img.addEventListener("error", () => {
        img.parentElement?.classList.add("missing");
      });
    }
  });
</script>
